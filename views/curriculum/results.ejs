<%- layout('layouts/boilerplate') %>

<div class="container mt-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <h2 class="mb-1">
        📘
        <% if (matchData.course_name) { %>
          <%= matchData.course_name %>
          <% if (matchData.course_code) { %>
            <span class="text-muted">(<%= matchData.course_code %>)</span>
          <% } %>
        <% } else { %>
          Curriculum Match Results
        <% } %>
      </h2>
      <% if (matchData.department) { %>
        <p class="text-muted mb-0"><%= matchData.department %></p>
      <% } %>
      <p class="text-muted small mb-0">Parsed from <strong><%= uploadedFilename || 'lecture plan' %></strong></p>
    </div>
    <a href="/curriculum" class="btn btn-outline-secondary">Upload Another</a>
  </div>

  <!-- ================================================================ -->
  <!-- Saved-snapshot banner                                             -->
  <!--                                                                   -->
  <!-- Shown when this page is rendering a saved curriculum (passed as   -->
  <!-- `savedCurriculum` by the GET /curriculum/:id route OR by the      -->
  <!-- POST /curriculum upload route after a successful save). Tells     -->
  <!-- the user this is a historical snapshot, not a fresh match, and    -->
  <!-- gives them a one-click delete to remove it from their profile.    -->
  <!-- ================================================================ -->
  <% if (typeof savedCurriculum !== 'undefined' && savedCurriculum) { %>
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
      <div>
        <strong>📌 Saved to your profile</strong>
        <span class="text-muted small ms-2">
          on <%= new Date(savedCurriculum.created_at).toLocaleString() %>
          — this is a snapshot. Re-upload the PDF for a fresh match.
        </span>
      </div>
      <form action="/curriculum/<%= savedCurriculum._id %>?_method=DELETE" method="POST" class="d-inline m-0"
            onsubmit="return confirm('Remove this saved curriculum from your profile?')">
        <button type="submit" class="btn btn-sm btn-outline-danger">Remove from profile</button>
      </form>
    </div>
  <% } %>


  <!-- Error -->
  <% if (matchData.error) { %>
    <div class="alert alert-danger">
      <strong>Could not process PDF:</strong> <%= matchData.error %>
      <br><small>Make sure the PDF contains selectable text (not a scanned image).</small>
    </div>
  <% } %>

  <!-- ============================================================== -->
  <!-- SECTION 1 — Professor's Recommended Books                       -->
  <!-- ============================================================== -->
  <% if (matchData.recommended_books && matchData.recommended_books.length > 0) { %>
    <div class="mb-5">
      <h4 class="mb-3">🎓 Professor's Recommended Books</h4>
      <p class="text-muted small mb-3">
        These are the textbooks &amp; references listed in your lecture plan. We checked our library for each.
      </p>

      <div class="row g-3">
        <% matchData.recommended_books.forEach(rec => { %>
          <div class="col-md-6">
            <div class="card h-100 border <%= rec.found ? 'border-success' : 'border-secondary' %>">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <% if (rec.found) { %>
                    <span class="badge bg-success">✅ Found in library</span>
                  <% } else { %>
                    <span class="badge bg-secondary">❌ Not in library</span>
                  <% } %>
                  <% if (rec.match_score > 0) { %>
                    <small class="text-muted"><%= Math.round(rec.match_score * 100) %>% match</small>
                  <% } %>
                </div>

                <h6 class="card-title mb-1">
                  <% if (rec.found && rec.book_title) { %>
                    <%= rec.book_title %>
                  <% } else { %>
                    <%= rec.recommended_title %>
                  <% } %>
                </h6>

                <% if (rec.found && rec.book_author) { %>
                  <p class="text-muted small mb-2"><%= rec.book_author %></p>
                <% } else if (rec.recommended_authors) { %>
                  <p class="text-muted small mb-2"><%= rec.recommended_authors %></p>
                <% } %>

                <p class="text-muted small mb-2">
                  <strong>From lecture plan:</strong>
                  <em><%= rec.recommended_title %></em><% if (rec.recommended_authors) { %> — <%= rec.recommended_authors %><% } %>
                </p>

                <% if (rec.found) { %>
                  <div class="mt-2">
                    <% if (rec.source_type === 'pdf') { %>
                      <span class="badge bg-light text-primary border border-primary">📄 Digital copy in library</span>
                      <% if (rec.cloudinary_url) { %>
                        <a href="<%= rec.cloudinary_url %>" target="_blank" class="btn btn-sm btn-outline-primary ms-2">Open PDF</a>
                      <% } %>
                      <a href="/pdfs/<%= rec.book_id %>" class="btn btn-sm btn-outline-secondary ms-1">Details →</a>
                    <% } else { %>
                      <% if (rec.available) { %>
                        <span class="badge bg-light text-success border border-success">📗 Available to borrow</span>
                      <% } else { %>
                        <span class="badge bg-light text-danger border border-danger">📕 Currently borrowed</span>
                      <% } %>
                      <a href="/books/<%= rec.book_id %>" class="btn btn-sm btn-outline-primary ms-2">View →</a>
                    <% } %>
                  </div>
                <% } else { %>
                  <p class="small text-muted mb-0 mt-2">
                    We'll recommend alternatives for each unit below.
                  </p>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- ============================================================== -->
  <!-- SECTION 2 — Unit → Chapter Map                                   -->
  <!-- ============================================================== -->
  <% if (matchData.unit_matches && matchData.unit_matches.length > 0) { %>
    <div class="mb-5">
      <h4 class="mb-3">📑 Unit → Chapter Map</h4>
      <p class="text-muted small mb-3">
        For each unit in your syllabus, we've identified the best book and specific chapter.
      </p>

      <% matchData.unit_matches.forEach(unit => { %>
        <div class="card mb-3 shadow-sm">
          <div class="card-body">

            <!-- Unit heading -->
            <div class="mb-2">
              <h5 class="mb-0">
                <% if (unit.unit_no) { %>
                  <span class="text-muted">Unit <%= unit.unit_no %> —</span>
                <% } %>
                <%= unit.unit_title %>
              </h5>
            </div>

            <!-- Book title + source badge -->
            <%
              // no_match = the unit-fallback path's LLM judge rejected the
              // cosine-argmax pick because no inventory book is genuinely
              // an alternative for this unit (e.g. OOP plan with only OS
              // textbooks in the library). Render an honest empty state
              // instead of a misleading wrong-domain suggestion.
              const isNoMatch = unit.source === 'no_match' || !unit.book_title;
            %>
            <div class="mb-2">
              <% if (isNoMatch) { %>
                <strong class="text-muted">📭 No matching book in our inventory</strong>
                <span class="badge bg-secondary ms-2">Inventory gap</span>
                <small class="text-muted d-block mt-1">
                  <%= unit.no_match_reason || "We couldn't find a book in our library that genuinely covers this unit. Try uploading the professor's textbook, or browse the digital PDF library for related notes." %>
                </small>
              <% } else { %>
                <strong>📘 <%= unit.book_title %></strong>
                <% if (unit.book_author) { %>
                  <span class="text-muted">— <%= unit.book_author %></span>
                <% } %>
                <% if (unit.source === 'professor_recommended') { %>
                  <span class="badge bg-success ms-2">🎓 Professor-recommended</span>
                <% } else { %>
                  <span class="badge bg-info text-dark ms-2">🤖 AI-suggested</span>
                  <small class="text-muted d-block mt-1">
                    Professor's recommended book was not available — this is the closest alternative in our library.
                  </small>
                <% } %>
              <% } %>
            </div>

            <!-- Chapter + page + confidence -->
            <% if (unit.suggested_chapter) { %>
              <div class="mb-2 ps-3 border-start border-3 border-primary">
                <p class="mb-1">
                  <strong>Chapter:</strong> <%= unit.suggested_chapter %>
                </p>

                <% if (unit.chapter_source === 'pdf' && unit.chapter_page) { %>
                  <span class="badge bg-success">
                    📍 Page <%= unit.chapter_page %> — from PDF index (accurate)
                  </span>
                <% } else if (unit.chapter_source === 'pdf') { %>
                  <span class="badge bg-primary">
                    📄 From PDF table of contents
                  </span>
                <% } else if (unit.chapter_source === 'physical') { %>
                  <span class="badge bg-warning text-dark">
                    📖 Chapter title only — check book's index for page
                  </span>
                <% } else if (unit.chapter_source === 'ai_guess') { %>
                  <span class="badge bg-warning text-dark">
                    🤖 AI-estimated (<%= unit.chapter_confidence || 'low' %> confidence)
                  </span>
                  <small class="text-muted d-block mt-1">
                    Chapter guessed from book metadata — verify from the book's index.
                  </small>
                <% } %>
              </div>
            <% } else { %>
              <p class="text-muted small mb-2 ps-3 border-start border-3 border-secondary">
                No chapter info available — book is still listed below.
              </p>
            <% } %>

            <!-- Match score -->
            <div class="mb-2">
              <div class="d-flex align-items-center gap-2">
                <small class="text-muted">Topic match:</small>
                <div class="progress" style="height: 6px; width: 100px;">
                  <div class="progress-bar bg-success" style="width: <%= Math.round(unit.match_score * 100) %>%"></div>
                </div>
                <small class="text-muted"><%= Math.round(unit.match_score * 100) %>%</small>
              </div>
            </div>

            <!-- Formats available -->
            <% if (unit.formats_available && unit.formats_available.length > 0) { %>
              <div class="mt-3">
                <small class="text-muted d-block mb-2">How to access:</small>

                <% unit.formats_available.forEach(fmt => { %>
                  <% if (fmt.type === 'physical') { %>
                    <a href="/books/<%= fmt.book_id %>"
                       class="btn btn-sm <%= fmt.available ? 'btn-outline-success' : 'btn-outline-secondary' %> me-2 mb-1">
                      📗 Borrow hard copy
                      <% if (fmt.available) { %>
                        <span class="badge bg-success ms-1">Available</span>
                      <% } else { %>
                        <span class="badge bg-secondary ms-1">Borrowed</span>
                      <% } %>
                    </a>
                  <% } else if (fmt.type === 'pdf') { %>
                    <%
                      // "Page-accurate" = this unit's chapter match actually
                      // came from the PDF's embedded TOC (chapter_source=='pdf')
                      // AND we have a real page number. We deliberately don't
                      // trust `fmt.page_accurate` alone — it's true whenever
                      // ANY PDF format exists, which mislabels AI-guessed
                      // chapters on PDF-backed units.
                      const unitIsPageAccurate =
                        unit.chapter_source === 'pdf' && unit.chapter_page;
                    %>
                    <a href="/pdfs/<%= fmt.pdf_id %>"
                       class="btn btn-sm btn-outline-primary me-2 mb-1">
                      📄 Open PDF
                      <% if (unitIsPageAccurate) { %>
                        <span class="badge bg-primary ms-1">p. <%= unit.chapter_page %></span>
                      <% } %>
                    </a>
                  <% } %>
                <% }) %>
              </div>
            <% } %>

          </div>
        </div>
      <% }) %>
    </div>
  <% } else if (!matchData.error) { %>
    <% if ((matchData.n_units_parsed || 0) === 0) { %>
      <div class="alert alert-warning">
        No units could be extracted from your lecture plan. Try a text-based PDF (not scanned).
      </div>
    <% } else { %>
      <div class="alert alert-info">
        <strong>Found <%= matchData.n_units_parsed %> unit<%= matchData.n_units_parsed === 1 ? '' : 's' %> in your lecture plan</strong>,
        but none matched a book or PDF in our library yet.
        <% if (matchData.recommended_books && matchData.recommended_books.length > 0) { %>
          Once someone lists the professor's recommended books above, chapter-level
          matches will appear here automatically.
        <% } else { %>
          Try uploading the relevant textbooks or PDFs to enable chapter-level matching.
        <% } %>
      </div>
    <% } %>
  <% } %>

  <!-- ============================================================== -->
  <!-- SECTION 3 — Course Notes & Previous Papers                     -->
  <!-- (PDFs tagged to this course/dept by peers — shown even when    -->
  <!--  unit matching fails, because notes help regardless.)           -->
  <!-- ============================================================== -->
  <% if (matchData.related_notes && matchData.related_notes.length > 0) {
       // group by resource_type so Notes / PYQs / Reference render separately
       const _groups = {};
       matchData.related_notes.forEach(n => {
         const rt = n.resource_type || 'notes';
         (_groups[rt] = _groups[rt] || []).push(n);
       });
       const _labels = {
         notes:           '📝 Peer Notes',
         previous_papers: '📄 Previous Year Papers',
         reference:       '📚 Reference Material',
         textbook:        '📘 Student-Uploaded Textbooks'
       };
  %>
    <div class="mb-5">
      <h4 class="mb-3">🗂️ Course Material in Our Library</h4>
      <p class="text-muted small mb-3">
        Peer-uploaded PDFs and physical listings for this course
        <% if (matchData.course_code) { %>(<%= matchData.course_code %>)<% } %>.
        Physical items marked 📗 can be borrowed; digital PDFs 📄 are free to download.
      </p>

      <% Object.keys(_groups).forEach(rt => { %>
        <h6 class="mt-3 mb-2"><%= _labels[rt] || rt %></h6>
        <div class="row g-3">
          <% _groups[rt].forEach(note => { %>
            <div class="col-md-6">
              <div class="card h-100 shadow-sm">
                <div class="card-body">
                  <h6 class="mb-1">
                    <% if (note.source_type === 'physical') { %>📗<% } else { %>📄<% } %>
                    <%= note.title %>
                  </h6>
                  <% if (note.subject) { %>
                    <p class="text-muted small mb-1"><%= note.subject %></p>
                  <% } %>
                  <% if (note.source_type === 'physical' && note.author) { %>
                    <p class="text-muted small mb-1">by <%= note.author %></p>
                  <% } %>
                  <p class="small mb-2">
                    <% if (note.course) { %>
                      <span class="badge bg-light text-dark me-1"><%= note.course %></span>
                    <% } %>
                    <% if (note.department) { %>
                      <span class="badge bg-light text-dark me-1"><%= note.department %></span>
                    <% } %>
                    <% if (note.professor) { %>
                      <span class="text-muted">by <%= note.professor %></span>
                    <% } %>
                    <% if (note.source_type === 'physical') { %>
                      <% if (note.available) { %>
                        <span class="badge bg-success">Available</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Currently borrowed</span>
                      <% } %>
                    <% } %>
                  </p>
                  <p class="text-muted small mb-2">
                    <em>Matched by:</em> <%= note.match_reason.replace(/_/g, ' ') %>
                  </p>
                  <% if (note.source_type === 'physical') { %>
                    <a href="/books/<%= note.book_id %>" class="btn btn-sm btn-outline-primary">
                      View listing
                    </a>
                  <% } else { %>
                    <% if (note.cloudinary_url) { %>
                      <a href="<%= note.cloudinary_url %>" target="_blank" class="btn btn-sm btn-outline-primary">
                        Open PDF
                      </a>
                    <% } %>
                    <% if (note.pdf_id) { %>
                      <a href="/pdfs/<%= note.pdf_id %>" class="btn btn-sm btn-outline-secondary">
                        Details
                      </a>
                    <% } %>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Footer nav -->
  <div class="mt-4 mb-5">
    <a href="/pdfs" class="btn btn-outline-secondary me-2">Browse Digital Library</a>
    <a href="/books" class="btn btn-outline-secondary me-2">Browse All Books</a>
    <a href="/" class="btn btn-outline-primary">Back to Home</a>
  </div>

</div>
