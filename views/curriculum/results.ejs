<%- layout('layouts/boilerplate') %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-start mb-3">
    <div>
      <h2>🎓 Curriculum Match Results</h2>
      <p class="text-muted mb-0">
        Found <strong><%= matchData.topics_found %></strong> topics in
        <strong><%= filename || 'lecture plan' %></strong>
      </p>
    </div>
    <a href="/curriculum" class="btn btn-outline-secondary">Upload Another</a>
  </div>

  <% if (matchData.error) { %>
    <div class="alert alert-danger">
      <strong>Could not process PDF:</strong> <%= matchData.error %>
      <br><small>Make sure the PDF contains selectable text (not a scanned image).</small>
    </div>
  <% } %>

  <% if (matchData.topics && matchData.topics.length > 0) { %>
    <!-- Topics extracted -->
    <div class="mb-4">
      <h5 class="text-muted">Topics Extracted</h5>
      <div class="d-flex flex-wrap gap-2">
        <% matchData.topics.forEach(topic => { %>
          <span class="badge bg-light text-dark border"><%= topic %></span>
        <% }) %>
      </div>
    </div>

    <!-- Matches -->
    <h5 class="mb-3">Book Recommendations by Topic</h5>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Lecture Topic</th>
            <th>Recommended Book</th>
            <th>Author</th>
            <th>Match</th>
            <th>Suggested Chapter</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% matchData.matches.forEach(match => { %>
            <tr>
              <td><strong><%= match.topic %></strong></td>
              <td><%= match.book_title %></td>
              <td class="text-muted"><small><%= match.book_author %></small></td>
              <td>
                <div class="progress" style="height: 6px; width: 60px;">
                  <div class="progress-bar bg-success" style="width: <%= Math.round(match.match_score * 100) %>%"></div>
                </div>
                <small class="text-muted"><%= Math.round(match.match_score * 100) %>%</small>
              </td>
              <td>
                <% if (match.suggested_chapter) { %>
                  <small class="text-primary">📄 <%= match.suggested_chapter %></small>
                  <small class="text-muted d-block">(<%= Math.round(match.chapter_score * 100) %>% match)</small>
                <% } else { %>
                  <small class="text-muted">—</small>
                <% } %>
              </td>
              <td>
                <% if (match.book_id) { %>
                  <a href="/books/<%= match.book_id %>" class="btn btn-sm btn-outline-primary">View Book</a>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else if (!matchData.error) { %>
    <div class="alert alert-warning">
      No topics could be extracted. Try uploading a text-based PDF (not scanned).
    </div>
  <% } %>

  <div class="mt-3">
    <a href="/pdfs" class="btn btn-outline-secondary me-2">Browse Digital Library</a>
    <a href="/" class="btn btn-outline-primary">Back to Home</a>
  </div>
</div>
