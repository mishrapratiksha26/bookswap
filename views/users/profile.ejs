<%layout('layouts/boilerplate')%>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  body { font-family: 'Poppins', sans-serif; background: linear-gradient(135deg, #f4f6f8, #e8f5ee); }
  .profile-wrapper { max-width: 960px; margin: 40px auto; padding: 0 16px; }
  .profile-card { background: #fff; border-radius: 20px; box-shadow: 0 6px 24px rgba(0,0,0,0.08); overflow: hidden; margin-bottom: 2rem; }
  .profile-header { background: linear-gradient(90deg, #198754, #34c759); padding: 2rem; color: #fff; }
  .profile-header h2 { font-weight: 700; margin: 0; }
  .profile-header p { margin: 4px 0 0; opacity: 0.85; font-size: 0.95rem; }
  .section { padding: 1.5rem 2rem; border-bottom: 1px solid #f0f0f0; }
  .section:last-child { border-bottom: none; }
  .section h4 { font-weight: 600; color: #198754; margin-bottom: 1rem; }
  .book-grid { display: flex; flex-wrap: wrap; gap: 1rem; }
  .book-thumb { width: 140px; background: #f8faf9; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.07); text-decoration: none; color: inherit; transition: transform 0.2s; }
  .book-thumb:hover { transform: translateY(-3px); }
  .book-thumb img { width: 100%; height: 160px; object-fit: cover; }
  .book-thumb-info { padding: 0.6rem; }
  .book-thumb-info p { margin: 0; font-size: 0.82rem; font-weight: 600; }
  .book-thumb-info span { font-size: 0.75rem; color: #666; }
  .request-card { background: #f8faf9; border-left: 4px solid #198754; border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 0.8rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
  .request-card.pending { border-left-color: #ffc107; }
  .request-card.approved { border-left-color: #198754; }
  .request-card.rejected { border-left-color: #dc3545; }
  .status-badge { font-size: 0.78rem; padding: 3px 10px; border-radius: 20px; font-weight: 600; }
  .badge-pending { background: #fff3cd; color: #856404; }
  .badge-approved { background: #d1e7dd; color: #0a3622; }
  .badge-rejected { background: #f8d7da; color: #58151c; }
  .empty-msg { color: #aaa; font-size: 0.9rem; font-style: italic; }
</style>

<div class="profile-wrapper">

  <!-- Profile Header -->
  <div class="profile-card">
    <div class="profile-header">
      <h2><%= user.username %></h2>
      <p><%= user.email %></p>
    </div>
  </div>

  <!-- Pending Borrow Requests (owner actions) -->
  <div class="profile-card">
    <div class="section">
      <h4>📬 Incoming Borrow Requests</h4>
      <% if (borrowRequests.length === 0) { %>
        <p class="empty-msg">No pending borrow requests.</p>
      <% } else { %>
        <% borrowRequests.forEach(request => { %>
          <%
            // Same null-guard as the My Borrow Requests block below — a
            // borrow document can outlive the book or borrower it points
            // to. Render a graceful placeholder rather than crash.
            const incBookTitle = (request.book && request.book.title) || '(book no longer available)';
            const incBorrower  = (request.borrower && request.borrower.username) || '(deleted user)';
          %>
          <div class="request-card">
            <div>
              <strong><%= incBorrower %></strong> wants to borrow <strong><%= incBookTitle %></strong>
              <% if (request.returnDate) { %><br><small class="text-muted">Return by: <%= new Date(request.returnDate).toLocaleDateString() %></small><% } %>
            </div>
            <div style="display:flex; gap:0.5rem;">
              <form action="/borrow/<%= request._id %>/accept" method="POST">
                <button class="btn btn-success btn-sm">Accept</button>
              </form>
              <form action="/borrow/<%= request._id %>/reject" method="POST">
                <button class="btn btn-danger btn-sm">Reject</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- My Borrow Requests (borrower view) -->
  <div class="profile-card">
    <div class="section">
      <h4>📤 My Borrow Requests</h4>
      <% if (myBorrowRequests.length === 0) { %>
        <p class="empty-msg">You haven't sent any borrow requests yet.</p>
      <% } else { %>
        <% myBorrowRequests.forEach(request => { %>
          <%
            // Defensive nulls: a borrow request's `book` or `owner` can be
            // null if the referenced document was deleted but the request
            // wasn't (Mongoose's populate returns null on dangling refs
            // rather than throwing). Render a graceful "deleted" state
            // instead of crashing the whole profile page.
            const bookTitle  = (request.book && request.book.title)  || '(book no longer available)';
            const ownerName  = (request.owner && request.owner.username) || '(deleted user)';
            const ownerLink  = request.owner && request.owner._id;
          %>
          <div class="request-card <%= request.status %>">
            <div>
              <strong><%= bookTitle %></strong> — owned by <strong><%= ownerName %></strong>
              <% if (request.returnDate) { %><br><small class="text-muted">Return by: <%= new Date(request.returnDate).toLocaleDateString() %></small><% } %>
            </div>
            <div style="display:flex; align-items:center; gap:0.8rem;">
              <span class="status-badge badge-<%= request.status %>"><%= request.status.toUpperCase() %></span>
              <% if (request.status === 'approved' && ownerLink) { %>
                <a href="/chat/<%= ownerLink %>" class="btn btn-sm btn-success">💬 Chat to arrange pickup</a>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- Books Currently Borrowing -->
  <div class="profile-card">
    <div class="section">
      <h4>📚 Books You Are Borrowing</h4>
      <% if (borrowedBooks.length === 0) { %>
        <p class="empty-msg">You haven't borrowed any books yet.</p>
      <% } else { %>
        <div class="book-grid">
          <% borrowedBooks.forEach(book => { %>
            <a href="/books/<%= book._id %>" class="book-thumb">
              <% if (book.images && book.images.length > 0) { %>
                <img src="<%= book.images[0].url %>" alt="<%= book.title %>">
              <% } %>
              <div class="book-thumb-info">
                <p><%= book.title %></p>
                <span><%= book.author %></span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Books Currently Lent Out -->
  <div class="profile-card">
    <div class="section">
      <h4>🤝 Books You've Lent Out</h4>
      <% if (activeLentRequests.length === 0) { %>
        <p class="empty-msg">No books currently lent out.</p>
      <% } else { %>
        <% activeLentRequests.forEach(request => { %>
          <div class="request-card approved">
            <div>
              <strong><%= request.book.title %></strong> — borrowed by <strong><%= request.borrower.username %></strong>
              <% if (request.returnDate) { %><br><small class="text-muted">Return by: <%= new Date(request.returnDate).toLocaleDateString() %></small><% } %>
            </div>
            <form action="/borrow/<%= request._id %>/return" method="POST">
              <button class="btn btn-outline-success btn-sm">Mark as Returned</button>
            </form>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- Books Posted -->
  <div class="profile-card">
    <div class="section">
      <h4>📖 Books Posted by You</h4>
      <% if (books.length === 0) { %>
        <p class="empty-msg">You haven't posted any books yet.</p>
      <% } else { %>
        <div class="book-grid">
          <% books.forEach(book => { %>
            <a href="/books/<%= book._id %>" class="book-thumb">
              <% if (book.images && book.images.length > 0) { %>
                <img src="<%= book.images[0].url %>" alt="<%= book.title %>">
              <% } %>
              <div class="book-thumb-info">
                <p><%= book.title %></p>
                <span><%= book.author %></span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

</div>