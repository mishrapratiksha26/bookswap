<% layout('layouts/boilerplate')%>

<style>
    .new-book-wrap {
        max-width: 680px;
        margin: 2.5rem auto;
        padding: 0 1.5rem;
    }
    .new-book-wrap h1 {
        font-weight: 700;
        font-size: 1.9rem;
        color: var(--bs-text);
        margin: 0 0 0.3rem;
        letter-spacing: -0.5px;
    }
    .new-book-wrap .subtitle {
        color: var(--bs-text-muted);
        margin-bottom: 2rem;
    }
    .form-card {
        background: var(--bs-surface);
        border: 1px solid var(--bs-border);
        border-radius: var(--bs-radius-lg);
        padding: 2rem;
        box-shadow: var(--bs-shadow-sm);
    }
    .format-toggle {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        padding: 0.3rem;
        background: var(--bs-surface-alt);
        border-radius: var(--bs-radius-md);
    }
    .format-toggle button {
        flex: 1;
        padding: 0.7rem 1rem;
        background: transparent;
        border: none;
        border-radius: var(--bs-radius-sm);
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--bs-text-muted);
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
    }
    .format-toggle button.active {
        background: var(--bs-surface);
        color: var(--bs-primary);
        box-shadow: var(--bs-shadow-sm);
    }
    .autofill-box {
        background: var(--bs-primary-light);
        border: 1px solid var(--bs-primary);
        border-radius: var(--bs-radius-md);
        padding: 1rem 1.1rem;
        margin-bottom: 1.5rem;
    }
    .autofill-box h4 {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--bs-primary);
        margin: 0 0 0.4rem;
    }
    .autofill-box p {
        font-size: 0.85rem;
        color: var(--bs-text);
        margin: 0 0 0.8rem;
    }
    .candidate-list {
        display: none;
        margin-top: 1rem;
        background: var(--bs-surface);
        border-radius: var(--bs-radius-md);
        max-height: 320px;
        overflow-y: auto;
    }
    .candidate {
        display: flex;
        gap: 0.8rem;
        padding: 0.7rem;
        border-bottom: 1px solid var(--bs-border);
        cursor: pointer;
        transition: background 0.15s;
    }
    .candidate:last-child { border-bottom: none; }
    .candidate:hover { background: var(--bs-primary-light); }
    .candidate img {
        width: 50px; height: 70px;
        object-fit: cover;
        border-radius: 4px;
        background: var(--bs-surface-alt);
        flex-shrink: 0;
    }
    .candidate-meta h5 {
        margin: 0 0 0.2rem;
        font-size: 0.95rem;
        color: var(--bs-text);
    }
    .candidate-meta p {
        margin: 0;
        font-size: 0.8rem;
        color: var(--bs-text-muted);
        line-height: 1.3;
    }
    .cover-preview {
        display: none;
        align-items: center;
        gap: 1rem;
        padding: 0.8rem;
        background: var(--bs-surface-alt);
        border-radius: var(--bs-radius-md);
        margin-bottom: 1rem;
    }
    .cover-preview img {
        width: 60px; height: 84px;
        object-fit: cover;
        border-radius: 4px;
    }
    .cover-preview .meta {
        flex: 1;
        font-size: 0.85rem;
        color: var(--bs-text-muted);
    }
    .help-text {
        font-size: 0.8rem;
        color: var(--bs-text-muted);
        margin-top: 0.3rem;
    }
</style>

<div class="new-book-wrap">
    <h1>Share a Resource</h1>
    <p class="subtitle">Lend a physical book or upload a PDF — same flow, we'll route it correctly.</p>

    <div class="form-card">
        <!-- ─── Format toggle ─────────────────────────────────────────────
             Unifies the physical-book and PDF upload flows visually while
             keeping the backend routes split (/books vs /pdfs) — each has
             its own validation and field shape, and merging them into one
             Resource model would force half-null columns. The toggle swaps
             which <form> element is visible; Google Books autofill above
             populates whichever is active.
          ───────────────────────────────────────────────────────────────── -->
        <div class="format-toggle" role="tablist">
            <button type="button" id="tab-physical" class="active" onclick="switchFormat('physical')">
                📗 Physical book
            </button>
            <button type="button" id="tab-pdf" onclick="switchFormat('pdf')">
                📄 PDF / digital
            </button>
        </div>

        <!-- ─── Google Books autofill (shared across both forms) ───────────
             Rationale: cuts data-entry friction AND improves recommendation
             quality (richer descriptions → better embeddings → better
             semantic search results downstream). Populates whichever form
             is currently visible — title/author/description/year/cover.
          ─────────────────────────────────────────────────────────────────── -->
        <div class="autofill-box">
            <h4>✨ Auto-fill from Google Books</h4>
            <p>Type the title (and optionally author), then click fetch — we'll look up the cover, description, and publication year.</p>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <input type="text" id="lookup-title"  class="form-control" placeholder="Book title" style="flex: 2 1 180px;">
                <input type="text" id="lookup-author" class="form-control" placeholder="Author (optional)" style="flex: 1 1 140px;">
                <button type="button" class="bs-btn bs-btn--primary" onclick="fetchMetadata()">
                    <span id="fetch-btn-label">🔍 Fetch</span>
                </button>
            </div>
            <div id="candidate-list" class="candidate-list"></div>
            <p id="autofill-status" style="color: var(--bs-text-muted); font-size: 0.8rem; margin: 0.6rem 0 0; display: none;"></p>
        </div>

        <!-- ─── Shared cover preview ─────────────────────────────────────
             Rendered once; read by whichever form is visible. On submit,
             the visible form's hidden cover_url input already carries the
             URL, so we don't need to duplicate the preview per form.
          ─────────────────────────────────────────────────────────────── -->
        <div id="cover-preview" class="cover-preview">
            <img id="cover-preview-img" src="" alt="Cover preview">
            <div class="meta">
                <div><strong>Cover selected from Google Books</strong></div>
                <div id="cover-preview-caption" style="margin-top: 0.2rem;"></div>
            </div>
            <button type="button" class="bs-btn bs-btn--ghost" onclick="clearCover()">Remove</button>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════
             FORM A — Physical book (posts to /books, nested book[...] keys)
             ═══════════════════════════════════════════════════════════════ -->
        <form id="form-physical" action="/books" method="POST" novalidate class="validated-form" enctype="multipart/form-data">
            <!-- Hidden: URL of cover fetched from Google Books. Server-side
                 POST /books checks this; if present + no file uploaded, it
                 stores {url, filename:""} in book.images so the cover flows
                 through the existing images[] pipeline without schema churn. -->
            <input type="hidden" id="physical-cover-url" name="book[cover_url]" value="">

            <div class="mb-3">
                <label class="form-label" for="title">Title:</label>
                <input class="form-control" type="text" id="title" name="book[title]" required>
            </div>

            <div class="mb-3">
                <label class="form-label" for="author">Author:</label>
                <input class="form-control" type="text" id="author" name="book[author]" required>
            </div>

            <div class="mb-3">
                <label class="input-group-text" for="inputGroupSelect01">Genre:</label>
                <select class="form-select" id="inputGroupSelect01" name="book[genre]" required
                        onchange="toggleEducationalFields(this.value)">
                    <option selected></option>
                    <option value="ACTION AND ADVENTURE">Adventure</option>
                    <option value="AUTOBIOGRAPHY/BIOGRAPHY">Autobiography/Biography</option>
                    <option value="SUSPENSE/THRILLERS">Suspense/Thriller</option>
                    <option value="EDUCATIONAL">Educational</option>
                    <option value="DETECTIVE AND MYSTERY">Detective and mystery</option>
                    <option value="RELIGIOUS">Religious</option>
                    <option value="HORROR">Horror</option>
                    <option value="ROMANCE">Romance</option>
                    <option value="FICTION">Fiction</option>
                    <option value="HISTORY">History</option>
                    <option value="INSPIRATION/MOTIVATIONAL">Inspiration/Motivational</option>
                    <option value="SELF_HELP">Self-help</option>
                </select>
            </div>

            <div id="educational-fields" style="display: none;">
                <div class="alert alert-info py-2 small">
                    📚 Academic material — help fellow students find it by course &amp; department.
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label" for="department">Department:</label>
                        <select class="form-select" id="department" name="book[department]">
                            <option value="" selected>Pick a department...</option>
                            <% departments.forEach(d => { %>
                                <option value="<%= d.code %>"><%= d.code %> — <%= d.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label" for="course">Course:</label>
                        <select class="form-select" id="course" name="book[course]" disabled>
                            <option value="" selected>Pick a department first...</option>
                        </select>
                        <div class="form-text" id="course-help">Optional — leave blank for generic material.</div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="resource_type">Type of material:</label>
                    <select class="form-select" id="resource_type" name="book[resource_type]">
                        <option value="textbook" selected>Textbook</option>
                        <option value="notes">Peer Notes (hand-written / printed)</option>
                        <option value="previous_papers">Previous Year Papers (hard copy)</option>
                        <option value="reference">Reference Material</option>
                    </select>
                </div>

                <div id="notes-extras" class="row mb-3" style="display: none;">
                    <div class="col">
                        <label class="form-label">Semester</label>
                        <select class="form-select" name="book[semester]">
                            <option value="">—</option>
                            <% for (let s = 1; s <= 10; s++) { %>
                                <option value="<%= s %>"><%= s %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label">Topic covered</label>
                        <input type="text" class="form-control" name="book[topic]" placeholder="e.g. Process scheduling, deadlocks">
                    </div>
                </div>

                <div id="pyq-extras" class="row mb-3" style="display: none;">
                    <div class="col">
                        <label class="form-label">Exam type</label>
                        <select class="form-select" name="book[exam_type]">
                            <option value="">—</option>
                            <option value="mid_sem">Mid-sem</option>
                            <option value="end_sem">End-sem</option>
                            <option value="quiz">Quiz / Class test</option>
                            <option value="assignment">Assignment</option>
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label">Exam Year</label>
                        <input type="number" class="form-control" name="book[year]" min="2000" max="2099" placeholder="e.g. 2024">
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="publication_year">Publication Year (optional):</label>
                <input class="form-control" type="number" id="publication_year"
                       name="book[publication_year]" min="1800" max="2100" placeholder="e.g. 2017">
            </div>

            <div class="mb-3">
                <label class="form-label">Or upload your own cover image(s):</label>
                <div class="form-file custom-file">
                    <input type="file" class="form-file-input" id="image" name="image" multiple>
                    <label class="form-file-label" for="image">
                        <span class="form-file-text custom-file-label">Choose image(s)...</span>
                        <span class="form-file-button">Browse</span>
                    </label>
                </div>
                <div class="help-text">Skip this if you've picked a cover from Google Books above.</div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="description">Book description:</label>
                <textarea class="form-control" type="text" id="description" name="book[description]" rows="5" required></textarea>
            </div>

            <%# Lending price field removed — second user-test session
                 confirmed BookSwap is positioned as a free peer-to-peer
                 lending platform, not a marketplace. The Mongoose
                 schema kept `price` as a backward-compatible field
                 with default 0 so older book documents render fine. %>
            <input type="hidden" name="book[price]" value="0">

            <div class="mb-3">
                <button class="bs-btn bs-btn--primary">Post book</button>
                <a href="/books" class="bs-btn bs-btn--ghost" style="margin-left: 0.5rem;">Cancel</a>
            </div>
        </form>

        <!-- ═══════════════════════════════════════════════════════════════
             FORM B — PDF / digital resource (posts to /pdfs, flat keys)
             Shown only when the user toggles to "PDF / digital" at top.
             Different field shape than Form A because the Pdf model has
             different required fields (no price, has professor +
             file upload). Keeping two forms avoids JS name-rewriting on
             submit, which is a common source of form bugs.
             ═══════════════════════════════════════════════════════════════ -->
        <form id="form-pdf" action="/pdfs" method="POST" novalidate class="validated-form" enctype="multipart/form-data" style="display: none;">
            <!-- Cover URL: stored as pdf.cover_url (new field on Pdf model).
                 Rendered on PDF cards + detail pages; falls back to a generic
                 icon when blank. Autofilled from Google Books; no file upload
                 path for PDF covers (intentional — keeps form light). -->
            <input type="hidden" id="pdf-cover-url" name="cover_url" value="">

            <div class="mb-3">
                <label class="form-label" for="pdf-title">Title:</label>
                <input class="form-control" type="text" id="pdf-title" name="title" required>
            </div>

            <%# Subject field removed — pilot user-test feedback ("no
                 need of subject in it"). The Course dropdown below
                 already encodes the same information ("MCC510 -
                 Operating Systems") and POST /pdfs derives the subject
                 string from the course when not supplied, keeping the
                 downstream pipeline (chapter extractor, search, recs)
                 working unchanged. Same fix applied earlier to the
                 standalone /pdfs/new form (which is now also reachable
                 from this unified upload page via the PDF tab). %>

            <div class="row mb-3">
                <div class="col">
                    <label class="form-label" for="pdf-department">Department:</label>
                    <select class="form-select" id="pdf-department" name="department">
                        <option value="" selected>Pick a department...</option>
                        <% departments.forEach(d => { %>
                            <option value="<%= d.code %>"><%= d.code %> — <%= d.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label" for="pdf-course">Course:</label>
                    <select class="form-select" id="pdf-course" name="course" disabled>
                        <option value="" selected>Pick a department first...</option>
                    </select>
                    <div class="form-text" id="pdf-course-help">Optional.</div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="pdf-professor">Professor (optional):</label>
                <input class="form-control" type="text" id="pdf-professor" name="professor"
                       placeholder="e.g. Prof. R. Kumar">
            </div>

            <div class="mb-3">
                <label class="form-label" for="pdf-resource-type">Type of material:</label>
                <select class="form-select" id="pdf-resource-type" name="resource_type">
                    <option value="textbook">Textbook / soft-copy</option>
                    <option value="notes" selected>Notes</option>
                    <option value="previous_papers">Previous Year Papers</option>
                    <option value="reference">Reference Material</option>
                </select>
            </div>

            <!-- Conditional PDF-specific extras, mirroring physical form's
                 notes-extras / pyq-extras pattern. Same JS toggler reused. -->
            <div id="pdf-notes-extras" class="row mb-3" style="display: none;">
                <div class="col">
                    <label class="form-label">Semester</label>
                    <select class="form-select" name="semester">
                        <option value="">—</option>
                        <% for (let s = 1; s <= 10; s++) { %>
                            <option value="<%= s %>"><%= s %></option>
                        <% } %>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">Topic covered</label>
                    <input type="text" class="form-control" name="topic" placeholder="e.g. Process scheduling">
                </div>
            </div>

            <div id="pdf-pyq-extras" class="row mb-3" style="display: none;">
                <div class="col">
                    <label class="form-label">Exam type</label>
                    <select class="form-select" name="exam_type">
                        <option value="">—</option>
                        <option value="mid_sem">Mid-sem</option>
                        <option value="end_sem">End-sem</option>
                        <option value="quiz">Quiz / Class test</option>
                        <option value="assignment">Assignment</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">Exam Year</label>
                    <input type="number" class="form-control" name="year" min="2000" max="2099" placeholder="e.g. 2024">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="pdf-description">Description:</label>
                <textarea class="form-control" id="pdf-description" name="description" rows="5"
                          placeholder="What does this PDF cover? Help other students find it."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label" for="pdf-file">PDF file:</label>
                <input type="file" class="form-control" id="pdf-file" name="pdf" accept="application/pdf" required>
                <div class="help-text">Max 20 MB. Will be hosted on Cloudinary and indexed for curriculum matching.</div>
            </div>

            <div class="mb-3">
                <button class="bs-btn bs-btn--primary">Upload PDF</button>
                <a href="/books" class="bs-btn bs-btn--ghost" style="margin-left: 0.5rem;">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
    // ─── Format toggle (Physical ↔ PDF) ─────────────────────────────────
    // Only one form is visible at a time. The shared Google Books widget
    // + cover preview above populate whichever is active, by reading a
    // data-attribute we set here ("physical" | "pdf").
    function switchFormat(fmt) {
        const physical = document.getElementById('form-physical');
        const pdf      = document.getElementById('form-pdf');
        const tabP     = document.getElementById('tab-physical');
        const tabD     = document.getElementById('tab-pdf');

        if (fmt === 'pdf') {
            physical.style.display = 'none';
            pdf.style.display      = '';
            tabP.classList.remove('active');
            tabD.classList.add('active');
        } else {
            physical.style.display = '';
            pdf.style.display      = 'none';
            tabP.classList.add('active');
            tabD.classList.remove('active');
        }
        document.body.dataset.activeForm = fmt;
        // Clear any previously-applied cover when switching — forces the
        // user to re-pick consciously for the new format, avoids confusion.
        clearCover();
    }
    // Default: physical.
    document.body.dataset.activeForm = 'physical';

    // Show/hide academic fields when genre changes (physical form only).
    function toggleEducationalFields(genre) {
        const block = document.getElementById('educational-fields');
        block.style.display = (genre === 'EDUCATIONAL') ? 'block' : 'none';
    }

    // ─── Department → Course cascade (applies to BOTH forms) ─────────────
    // Each form has its own dept + course selects, wired independently so
    // switching format doesn't leak state.
    (function () {
        const cache = {};   // shared — same API, same cache key by dept code

        async function loadCourses(deptCode, courseSelect, courseHelp) {
            courseSelect.disabled = true;
            courseSelect.innerHTML = '<option value="">Loading...</option>';
            let courses = cache[deptCode];
            if (!courses) {
                try {
                    const resp = await fetch(`/api/courses?dept=${encodeURIComponent(deptCode)}`);
                    if (!resp.ok) throw new Error('fetch failed');
                    const data = await resp.json();
                    courses = data.courses || [];
                    cache[deptCode] = courses;
                } catch (e) {
                    courseSelect.innerHTML = '<option value="">Could not load courses</option>';
                    if (courseHelp) courseHelp.textContent = 'Failed to load courses.';
                    courseSelect.disabled = false;
                    return;
                }
            }
            courseSelect.innerHTML = '<option value="">— No specific course —</option>' +
                courses.map(c => {
                    const label = `${c.code} — ${c.name}` + (c.type && c.type !== '—' ? ` (${c.type})` : '');
                    const value = `${c.code} - ${c.name}`;
                    return `<option value="${value}">${label}</option>`;
                }).join('');
            courseSelect.disabled = false;
            if (courseHelp) courseHelp.textContent = `${courses.length} courses in this department. Optional.`;
        }

        // Physical form
        const pDept   = document.getElementById('department');
        const pCourse = document.getElementById('course');
        const pHelp   = document.getElementById('course-help');
        if (pDept && pCourse) {
            pDept.addEventListener('change', e => {
                if (e.target.value) loadCourses(e.target.value, pCourse, pHelp);
            });
        }
        // PDF form
        const dDept   = document.getElementById('pdf-department');
        const dCourse = document.getElementById('pdf-course');
        const dHelp   = document.getElementById('pdf-course-help');
        if (dDept && dCourse) {
            dDept.addEventListener('change', e => {
                if (e.target.value) loadCourses(e.target.value, dCourse, dHelp);
            });
        }
    })();

    // ─── Resource-type → conditional extras (both forms) ────────────────
    (function () {
        function wire(selectId, notesId, pyqId) {
            const sel = document.getElementById(selectId);
            const n   = document.getElementById(notesId);
            const p   = document.getElementById(pyqId);
            if (!sel) return;
            function sync() {
                const v = sel.value;
                if (n) n.style.display = (v === 'notes') ? '' : 'none';
                if (p) p.style.display = (v === 'previous_papers') ? '' : 'none';
            }
            sel.addEventListener('change', sync);
            sync();
        }
        wire('resource_type',     'notes-extras',     'pyq-extras');
        wire('pdf-resource-type', 'pdf-notes-extras', 'pdf-pyq-extras');
    })();

    // ─── Google Books autofill ──────────────────────────────────────────
    async function fetchMetadata() {
        const title  = document.getElementById('lookup-title').value.trim();
        const author = document.getElementById('lookup-author').value.trim();
        const status = document.getElementById('autofill-status');
        const listEl = document.getElementById('candidate-list');
        const label  = document.getElementById('fetch-btn-label');

        if (!title) {
            status.textContent = 'Please enter a title first.';
            status.style.display = 'block';
            return;
        }

        label.textContent = '⏳ Searching…';
        status.style.display = 'none';
        listEl.style.display = 'none';
        listEl.innerHTML = '';

        try {
            const params = new URLSearchParams({ title });
            if (author) params.append('author', author);
            const resp = await fetch(`/api/book-metadata?${params.toString()}`);
            const data = await resp.json();

            if (!data.found || !data.candidates || !data.candidates.length) {
                status.textContent = 'No matches found — fill the form manually.';
                status.style.display = 'block';
                return;
            }

            data.candidates.forEach(c => {
                const row = document.createElement('div');
                row.className = 'candidate';
                row.innerHTML = `
                    <img src="${c.cover_url || 'https://res.cloudinary.com/douqbebwk/image/upload/v1600103881/YelpCamp/lz8jjv2gyynjil7lswf4.png'}" alt="cover">
                    <div class="candidate-meta">
                        <h5>${escapeHtml(c.title)}</h5>
                        <p><strong>${escapeHtml((c.authors || []).join(', ')) || 'Unknown author'}</strong>
                           ${c.publication_year ? ' · ' + c.publication_year : ''}
                           ${c.page_count ? ' · ' + c.page_count + 'pp' : ''}
                        </p>
                        <p style="margin-top: 0.3rem;">${escapeHtml((c.description || '').slice(0, 140))}${c.description && c.description.length > 140 ? '…' : ''}</p>
                    </div>
                `;
                row.onclick = () => applyCandidate(c);
                listEl.appendChild(row);
            });
            listEl.style.display = 'block';
        } catch (err) {
            status.textContent = 'Lookup failed — please fill the form manually.';
            status.style.display = 'block';
        } finally {
            label.textContent = '🔍 Fetch';
        }
    }

    // Map Google Books' free-text `categories` array onto our genre enum.
    // Google returns labels like "Self-Help", "Biography & Autobiography",
    // "Juvenile Fiction" — we normalise them to the closest BookSwap
    // option. Returns the matching enum value or empty string for "no
    // confident match" (in which case the user picks manually).
    //
    // Order matters: more-specific patterns first. INSPIRATION /
    // MOTIVATIONAL is checked early because Google often tags Atomic
    // Habits / The 7 Habits / Mindset / Grit etc. as "Self-Help" or
    // "Psychology / Personal Growth" — both should map there.
    const GENRE_MAP = [
        // [regex over a single category string, our enum value]
        [/self.?help|personal\s*growth|motivation|inspiration|self.?improvement/i, 'INSPIRATION/MOTIVATIONAL'],
        [/biograph|autobiograph|memoir/i,                                          'AUTOBIOGRAPHY/BIOGRAPHY'],
        [/thriller|suspense/i,                                                     'SUSPENSE/THRILLERS'],
        [/mystery|detective|crime/i,                                               'DETECTIVE AND MYSTERY'],
        [/horror|supernatural/i,                                                   'HORROR'],
        [/romance/i,                                                               'ROMANCE'],
        [/religion|spiritual|theolog/i,                                            'RELIGIOUS'],
        [/history|historical/i,                                                    'HISTORY'],
        [/computer|programming|engineering|mathematics|physics|chemistry|biology|textbook|education|study\s*guide|reference/i,
                                                                                   'EDUCATIONAL'],
        [/adventure|action/i,                                                      'ACTION AND ADVENTURE'],
        [/fiction|fantasy|sci.?fi|science\s*fiction/i,                             'FICTION'],
    ];
    function inferGenre(categories) {
        for (const cat of (categories || [])) {
            for (const [re, value] of GENRE_MAP) {
                if (re.test(cat)) return value;
            }
        }
        return '';
    }

    // Paste the chosen candidate into the CURRENTLY-VISIBLE form.
    // Both forms get the cover URL; description/year/title/author flow to
    // whichever form matches the field shape (physical vs pdf).
    function applyCandidate(c) {
        const fmt = document.body.dataset.activeForm || 'physical';

        if (fmt === 'physical') {
            document.getElementById('title').value       = c.title || '';
            document.getElementById('author').value      = (c.authors || []).join(', ');
            document.getElementById('description').value = c.description || '';
            if (c.publication_year) document.getElementById('publication_year').value = c.publication_year;
            document.getElementById('physical-cover-url').value = c.cover_url || '';

            // Auto-fill genre from Google Books `categories`. The user
            // can still change it — this is a hint, not a lock-in.
            const inferred = inferGenre(c.categories);
            if (inferred) {
                const sel = document.getElementById('inputGroupSelect01');
                if (sel) {
                    sel.value = inferred;
                    // Fire the existing change handler so the
                    // EDUCATIONAL course/department block toggles
                    // visibility correctly when applicable.
                    sel.dispatchEvent(new Event('change'));
                }
            }
        } else {
            document.getElementById('pdf-title').value       = c.title || '';
            document.getElementById('pdf-description').value = c.description || '';
            // Subject stays user-entered — Google Books doesn't give us a
            // clean "subject" (only free-text categories), and IIT subject
            // names are local (e.g. "Operating Systems" vs Google's "Computers").
            document.getElementById('pdf-cover-url').value   = c.cover_url || '';
        }

        // Show the shared cover preview.
        if (c.cover_url) {
            document.getElementById('cover-preview-img').src = c.cover_url;
            document.getElementById('cover-preview-caption').textContent =
                `${c.title}${(c.authors && c.authors.length) ? ' — ' + c.authors.join(', ') : ''}`;
            document.getElementById('cover-preview').style.display = 'flex';
        } else {
            clearCover();
        }

        document.getElementById('candidate-list').style.display = 'none';
        const status = document.getElementById('autofill-status');
        status.innerHTML = `✅ Applied: <strong>${escapeHtml(c.title)}</strong>. Review and adjust as needed.`;
        status.style.display = 'block';
    }

    // Remove a previously-applied cover — clears both hidden inputs + preview.
    function clearCover() {
        const p = document.getElementById('physical-cover-url');
        const d = document.getElementById('pdf-cover-url');
        if (p) p.value = '';
        if (d) d.value = '';
        const prev = document.getElementById('cover-preview');
        if (prev) prev.style.display = 'none';
    }

    // Tiny XSS guard — Google Books description could contain entities.
    function escapeHtml(s) {
        if (!s) return '';
        return String(s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
</script>
