<% layout('layouts/boilerplate') %>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #f4f6f8, #e8f5ee);
    min-height: 100vh;
  }
  .container { max-width: 1150px; }
  .book-section { display: flex; flex-wrap: wrap; gap: 2rem; }
  .book-card {
    flex: 1 1 48%;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    overflow: hidden;
    padding: 1.5rem;
  }
  .carousel-inner { border-radius: 12px; overflow: hidden; }
  .card-img-top {
    width: 100%;
    height: 380px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
  }
  .book-title {
    font-size: 1.7rem;
    font-weight: 600;
    color: #222;
    margin-top: 1rem;
    text-align: center;
  }
  .book-info p { margin: 0.5rem 0; color: #444; font-size: 0.95rem; }
  .btn-gradient {
    background: linear-gradient(90deg, #198754, #34c759);
    color: #fff !important;
    border: none;
    padding: 0.6rem 1.3rem;
    border-radius: 8px;
    font-weight: 500;
    transition: 0.3s ease;
  }
  .btn-gradient:hover {
    background: linear-gradient(90deg, #157347, #28a745);
    transform: translateY(-2px);
  }
  .btn-outline-danger { border-radius: 6px; }
  .review-section { flex: 1 1 48%; }
  .review-form, .review-list {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }
  .review-form h4 { font-weight: 600; color: #222; margin-bottom: 1rem; }
  .review-card {
    background: #f8faf9;
    border-left: 5px solid #34c759;
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 1rem;
  }
  .review-card h5 { font-size: 1rem; font-weight: 600; color: #198754; }
  .review-card p { color: #333; font-size: 0.95rem; }
  .review-card .card-subtitle { font-size: 0.85rem; }
  @media (max-width: 992px) {
    .book-section { flex-direction: column; }
    .book-card, .review-section { flex: 1 1 100%; }
  }

  /* Cluster — "Other copies available from…" */
  .copies-section {
    background: #fff;
    border-radius: 16px;
    padding: 1.8rem;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    margin-top: 2.5rem;
  }
  .copies-section h3 {
    font-weight: 600;
    color: #222;
    margin: 0 0 0.4rem;
    font-size: 1.2rem;
  }
  .copies-section .hint {
    color: #666;
    font-size: 0.88rem;
    margin: 0 0 1.2rem;
  }
  .copy-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    margin-bottom: 0.6rem;
    transition: all 0.15s;
  }
  .copy-row:hover { border-color: #0f766e; background: #f0fdfa; }
  .copy-owner {
    font-weight: 600;
    color: #1f2937;
    font-size: 0.95rem;
  }
  .copy-meta {
    color: #6b7280;
    font-size: 0.82rem;
    margin-top: 0.1rem;
  }
  .copy-status {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
    white-space: nowrap;
  }
  .copy-status--available { background: #d1fae5; color: #065f46; }
  .copy-status--borrowed  { background: #fee2e2; color: #991b1b; }
  .copy-actions { display: flex; gap: 0.5rem; align-items: center; }
  .copy-view-btn {
    background: #0f766e;
    color: #fff !important;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.2s;
  }
  .copy-view-btn:hover { background: #115e59; }
</style>

<div class="container py-5">
  <div class="book-section">

    <!-- Book Card -->
    <div class="book-card">
      <div id="bookCarousel" class="carousel slide carousel-fade mb-3" data-bs-ride="carousel">
        <div class="carousel-inner">
          <% book.images.forEach((img, i) => { %>
            <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
              <img src="<%= img.url %>" class="card-img-top d-block w-100" alt="Book image">
            </div>
          <% }) %>
        </div>
        <% if (book.images.length > 1) { %>
          <button class="carousel-control-prev" type="button" data-bs-target="#bookCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#bookCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        <% } %>
      </div>

<div class="book-title"><%= book.title %></div>
<div class="book-info mt-3">
  <p><strong>Author:</strong> <%= book.author %></p>
  <p><strong>Genre:</strong> <%= book.genre %></p>
  <p><strong>MRP:</strong> ₹<%= book.price %></p>
  <p><strong>Description:</strong> <%= book.description %></p>
  <p><strong>Posted by:</strong> <%= book.owner.username %></p>
</div>

<div class="text-center mt-3">
  <%
    // Hide wishlist button if user is already borrowing (approved request) —
    // doesn't make sense to "wish for" a book you currently have.
    const hasApprovedBorrow = userBorrowRequest && userBorrowRequest.status === 'approved';
  %>
  <% if (currentUserId && currentUserId.toString() !== ownerId.toString() && !hasApprovedBorrow) { %>
    <!-- Wishlist toggle (only shown to non-owners who don't already have an
         approved borrow for this copy). Heart state comes from the server
         so first paint matches ground truth with no flicker. -->
    <button
      id="wishlist-toggle"
      class="bs-wishlist-btn <%= isWishlisted ? 'is-saved' : '' %>"
      onclick="toggleDetailWishlist('<%= book._id %>')">
      <span id="wl-icon"><%= isWishlisted ? '❤️' : '🤍' %></span>
      <span id="wl-label"><%= isWishlisted ? 'Saved to Wishlist' : 'Save to Wishlist' %></span>
    </button>
  <% } %>

  <% if (currentUserId && currentUserId.toString() === ownerId.toString()) { %>
    <a class="btn btn-info me-2" href="/books/<%= book._id %>/edit">Edit</a>
    <form class="d-inline" action="/books/<%= book._id %>?_method=DELETE" method="POST">
      <button class="btn btn-danger">Delete</button>
    </form>

  <% } else if (currentUserId) { %>
    <% if (userBorrowRequest && userBorrowRequest.status === 'pending') { %>
      <span class="badge bg-warning mt-2 p-2" style="font-size:0.9rem;">⏳ Borrow request already submitted</span>

    <% } else if (userBorrowRequest && userBorrowRequest.status === 'approved') { %>
      <span class="badge bg-success mt-2 p-2 d-block mb-2" style="font-size:0.9rem;">✅ You are borrowing this book</span>
      <a class="btn btn-gradient mt-2" href="/chat/<%= book.owner._id %>">
        💬 Chat with Owner to arrange pickup
      </a>

    <% } else if (book.available) { %>
      <form action="/books/<%= book._id %>/borrow" method="POST">
        <div id="borrowDateSection" style="display:none;" class="mb-2 text-start">
          <label class="form-label">Return Date (optional)</label>
          <input type="date" name="returnDate" class="form-control">
        </div>
        <button type="button" id="requestBorrowBtn" class="btn btn-gradient mt-2"
          onclick="
            document.getElementById('borrowDateSection').style.display='block';
            document.getElementById('requestBorrowBtn').style.display='none';
            document.getElementById('confirmBorrowBtn').style.display='inline-block';
          ">
          Request to Borrow
        </button>
        <button type="submit" id="confirmBorrowBtn" class="btn btn-gradient mt-2" style="display:none;">
          Confirm Request
        </button>
      </form>

    <% } else { %>
      <% if (activeBorrowRequest && activeBorrowRequest.returnDate) { %>
        <span class="badge bg-danger mt-2 p-2">Unavailable until <%= new Date(activeBorrowRequest.returnDate).toLocaleDateString() %></span>
      <% } else { %>
        <span class="badge bg-danger mt-2 p-2">Currently Unavailable</span>
      <% } %>
    <% } %>

  <% } else { %>
    <div class="alert alert-warning mt-2">
      <a href="/login" class="alert-link">Login</a> to borrow this book
    </div>
  <% } %>
</div>
</div>
<!-- End Book Card -->

    <!-- Review Section -->
    <div class="review-section">
      <% if (currentUserId) { %>
        <div class="review-form mb-4">
          <h4>Leave a Review</h4>
          <form action="/books/<%= book._id %>/reviews" method="POST">
            <div class="mb-3">
              <label for="rating" class="form-label">Rating</label>
              <input type="range" class="form-range" min="1" max="5" name="review[rating]" id="rating">
            </div>
            <div class="mb-3">
              <label for="body" class="form-label">Review</label>
              <textarea class="form-control" name="review[body]" id="body" rows="3" required></textarea>
            </div>
            <button class="btn btn-gradient">Submit</button>
          </form>
        </div>
      <% } else { %>
        <div class="alert alert-warning">
          Login to leave a review: <a href="/login" class="alert-link">Login</a>
        </div>
      <% } %>

      <div class="review-list">
        <% if (book.reviews.length === 0) { %>
          <p class="text-muted">No reviews yet.</p>
        <% } %>
        <% book.reviews.forEach(review => { %>
          <div class="review-card">
            <h5>Rating: <%= review.rating %> ⭐</h5>
            <p><%= review.body %></p>
            <h6 class="card-subtitle text-muted">By <%= review.author.username %></h6>
            <% if (currentUserId && review.author._id.toString() === currentUserId.toString()) { %>
              <form action="/books/<%= book._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-2">
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
    <!-- End Review Section -->

  </div>

  <script>
    // Toggle wishlist from the show page. Updates the button text + icon
    // immediately — no page reload.
    async function toggleDetailWishlist(bookId) {
        const btn   = document.getElementById('wishlist-toggle');
        const icon  = document.getElementById('wl-icon');
        const label = document.getElementById('wl-label');
        try {
            const resp = await fetch(`/wishlist/${bookId}/toggle`, {
                method: 'POST',
                headers: { 'Accept': 'application/json' }
            });
            if (!resp.ok) {
                if (resp.status === 401) { window.location.href = '/login'; return; }
                throw new Error();
            }
            const data = await resp.json();
            if (data.saved) {
                btn.classList.add('is-saved');
                icon.textContent  = '❤️';
                label.textContent = 'Saved to Wishlist';
            } else {
                btn.classList.remove('is-saved');
                icon.textContent  = '🤍';
                label.textContent = 'Save to Wishlist';
            }
        } catch (e) {
            console.error('Wishlist toggle failed', e);
        }
    }
  </script>

  <!-- Other Copies (cluster siblings) ─────────────────────────────
       Shown when the same title+author has been listed by other owners.
       Borrow flow stays per-listing — user clicks a specific copy's
       "View" link to go to that listing's detail page, where the normal
       borrow/chat/review machinery kicks in. This preserves the existing
       BorrowRequest → owner pairing without having to refactor it.
       ──────────────────────────────────────────────────────────────── -->
  <% if (otherCopies && otherCopies.length > 0) { %>
    <div class="copies-section">
      <h3>📚 Other copies of this book</h3>
      <p class="hint">
        <%= otherCopies.length %> other
        <%= otherCopies.length === 1 ? 'student has' : 'students have' %>
        listed this book. Check who has it available now.
      </p>
      <% otherCopies.forEach(copy => { %>
        <div class="copy-row">
          <div>
            <div class="copy-owner">
              <%= copy.owner_doc ? copy.owner_doc.username : 'Unknown' %>
            </div>
            <div class="copy-meta">
              <% if (typeof copy.avg_rating === 'number' && copy.avg_rating > 0) { %>
                ⭐ <%= copy.avg_rating.toFixed(1) %> ·
              <% } %>
              ₹<%= copy.price %>
            </div>
          </div>
          <div class="copy-actions">
            <% if (copy.available) { %>
              <span class="copy-status copy-status--available">✅ Available</span>
            <% } else { %>
              <span class="copy-status copy-status--borrowed">❌ Borrowed</span>
            <% } %>
            <a class="copy-view-btn" href="/books/<%= copy._id %>">View</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Similar Books -->
  <% if (similarBooks && similarBooks.length > 0) { %>
    <div class="similar-section mt-5">
      <h3 class="similar-heading">You might also like</h3>
      <div class="similar-grid">
        <% similarBooks.forEach(b => { %>
          <a href="/books/<%= b._id %>" class="similar-card-link">
            <div class="similar-card">
              <% if (b.images && b.images.length > 0) { %>
                <img src="<%= b.images[0].url %>" class="similar-card__img" alt="<%= b.title %>">
              <% } %>
              <p class="similar-card__title"><%= b.title %></p>
              <p class="similar-card__author"><%= b.author %></p>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <style>
    /* Similar-books cards. Using classes (not inline styles) so dark-mode
       overrides in app.css can actually reach them — inline styles would
       have won the cascade. */
    .similar-heading {
      font-weight: 600;
      color: var(--bs-text, #222);
      margin: 0 0 1rem;
    }
    .similar-grid {
      display: flex; gap: 1.5rem; flex-wrap: wrap;
    }
    .similar-card-link { text-decoration: none; color: inherit; }
    .similar-card {
      background: var(--bs-surface, #fff);
      border: 1px solid var(--bs-border, transparent);
      border-radius: 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
      padding: 1rem;
      width: 180px;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .similar-card:hover { transform: translateY(-3px); box-shadow: 0 10px 26px rgba(0,0,0,0.14); }
    .similar-card__img {
      width: 100%; height: 200px; object-fit: cover; border-radius: 10px;
    }
    .similar-card__title {
      font-weight: 600;
      margin: 0.6rem 0 0.2rem;
      font-size: 0.9rem;
      color: var(--bs-text, #1f2937);
    }
    .similar-card__author {
      margin: 0;
      color: var(--bs-text-muted, #666);
      font-size: 0.8rem;
    }
  </style>

</div>