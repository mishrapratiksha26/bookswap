<% layout('layouts/boilerplate') %>

<style>
  body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #f3f7fa, #e2f4ea);
    background-attachment: fixed;
    margin: 0;
    padding: 0;
    color: #1e1f31;
  }

  .page-title {
    font-weight: 700;
    font-size: 2.5rem;
    text-align: center;
    margin: 2.5rem 0 3.5rem;
    color: #2f3336;
    letter-spacing: 1px;
    position: relative;
  }

  .page-title::after {
    content: '';
    width: 70px;
    height: 4px;
    background: #2f3336;
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 2px;
  }

  .search-container {
    max-width: 600px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
    display: flex;
    gap: 0.75rem;
  }

  .search-input {
    flex: 1;
    padding: 12px 20px;
    border-radius: 25px;
    border: 2px solid #00a98f;
    font-size: 1rem;
    font-family: 'Poppins', sans-serif;
    outline: none;
    transition: box-shadow 0.3s ease;
  }

  .search-input:focus {
    box-shadow: 0 0 0 3px rgba(0, 169, 143, 0.2);
  }

  .search-btn {
    padding: 12px 24px;
    background-color: #00a98f;
    color: white;
    border: none;
    border-radius: 25px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .search-btn:hover {
    background-color: #008f7a;
    transform: scale(1.06);
  }

  .section-label {
    font-size: 1.2rem;
    font-weight: 600;
    color: #00a98f;
    max-width: 1300px;
    margin: 0 auto 1.5rem;
    padding: 0 1.5rem;
  }

  .divider {
    max-width: 1300px;
    margin: 3rem auto;
    border: none;
    border-top: 2px dashed #ccc;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    padding: 0 1.5rem 4rem;
    max-width: 1300px;
    margin: 0 auto;
  }

  .rec-grid {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 0 1.5rem 2rem;
    max-width: 1300px;
    margin: 0 auto;
  }

  .rec-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    padding: 1rem;
    width: 180px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s;
  }

  .rec-card:hover {
    transform: translateY(-4px);
  }

  .rec-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 10px;
  }

  .rec-card p { margin: 0; }
  .rec-card .rec-title { font-weight: 600; margin-top: 0.5rem; font-size: 0.9rem; }
  .rec-card .rec-author { color: #666; font-size: 0.8rem; }

  .card {
    background: rgba(255, 255, 255, 0.8);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    position: relative;  /* anchor for the floating wishlist heart */
  }

  .card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.25);
  }

  .card-img-top {
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-grow: 1;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    text-align: center;
    color: #222;
    margin-bottom: 0.5rem;
  }

  .card-text {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.6;
    text-align: justify;
  }

  .description-snippet {
    max-height: 3.9em;
    overflow: hidden;
    position: relative;
  }

  .description-snippet::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.3em;
    background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.9));
  }

  .btn-primary {
    background-color: #00a98f;
    border: none;
    border-radius: 25px;
    padding: 10px 22px;
    font-weight: 600;
    color: white;
    text-decoration: none;
    text-align: center;
    display: inline-block;
    margin-top: 1.2rem;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background-color: #008f7a;
    transform: scale(1.06);
  }
</style>

<h1 class="page-title">Discover Books</h1>

<!-- Search Bar -->
<form class="search-container" action="/books" method="GET">
  <input
    class="search-input"
    type="text"
    name="query"
    placeholder="Search by meaning... try 'inspirational story' or 'thrilling mystery'"
    value="<%= query %>"
  >
  <button class="search-btn" type="submit">Search</button>
</form>

<!-- Filter Bar -->
<form class="filter-container" action="/books" method="GET">
  <input type="hidden" name="query" value="<%= query %>">

  <select name="genre" class="filter-select">
    <option value="">All Genres</option>
    <% const genres = ["ACTION AND ADVENTURE","AUTOBIOGRAPHY/BIOGRAPHY","SUSPENSE/THRILLERS","EDUCATIONAL","DETECTIVE AND MYSTERY","RELIGIOUS","HORROR","ROMANCE","FICTION","HISTORY"]; %>
    <% genres.forEach(g => { %>
      <option value="<%= g %>" <%= (typeof filters !== 'undefined' && filters.genre === g) ? 'selected' : '' %>><%= g %></option>
    <% }) %>
  </select>

  <input type="text" name="author" class="filter-input" placeholder="Author..."
         value="<%= (typeof filters !== 'undefined' && filters.author) || '' %>">

  <input type="text" name="department" class="filter-input" list="filter-dept-list"
         placeholder="Department..."
         value="<%= (typeof filters !== 'undefined' && filters.department) || '' %>">
  <datalist id="filter-dept-list">
    <% if (typeof distinctDepartments !== 'undefined') { %>
      <% distinctDepartments.forEach(d => { %>
        <option value="<%= d %>"></option>
      <% }) %>
    <% } %>
  </datalist>

  <input type="text" name="course" class="filter-input" list="filter-course-list"
         placeholder="Course code..."
         value="<%= (typeof filters !== 'undefined' && filters.course) || '' %>">
  <datalist id="filter-course-list">
    <% if (typeof distinctCourses !== 'undefined') { %>
      <% distinctCourses.forEach(c => { %>
        <option value="<%= c %>"></option>
      <% }) %>
    <% } %>
  </datalist>

  <input type="number" name="year" class="filter-input" style="width: 100px;"
         placeholder="Year"
         value="<%= (typeof filters !== 'undefined' && filters.year) || '' %>">

  <select name="min_rating" class="filter-select">
    <option value="">Any Rating</option>
    <option value="4" <%= (typeof filters !== 'undefined' && filters.min_rating == '4') ? 'selected' : '' %>>4★ &amp; up</option>
    <option value="3" <%= (typeof filters !== 'undefined' && filters.min_rating == '3') ? 'selected' : '' %>>3★ &amp; up</option>
    <option value="2" <%= (typeof filters !== 'undefined' && filters.min_rating == '2') ? 'selected' : '' %>>2★ &amp; up</option>
  </select>

  <label class="filter-check">
    <input type="checkbox" name="available" value="true"
      <%= (typeof filters !== 'undefined' && filters.available === 'true') ? 'checked' : '' %>>
    Available only
  </label>

  <select name="sort" class="filter-select">
    <option value="">Sort: Newest</option>
    <option value="rating" <%= (typeof filters !== 'undefined' && filters.sort === 'rating') ? 'selected' : '' %>>Top Rated</option>
    <option value="title"  <%= (typeof filters !== 'undefined' && filters.sort === 'title')  ? 'selected' : '' %>>Title A→Z</option>
  </select>

  <button type="submit" class="filter-btn">Apply</button>
  <a href="/books" class="filter-clear">Clear</a>
</form>

<style>
  .filter-container {
    max-width: 1300px;
    margin: 0 auto 2.5rem;
    padding: 1rem 1.5rem;
    display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;
    background: rgba(255,255,255,0.6);
    border-radius: 12px;
    border: 1px solid #e1e7e2;
  }
  .filter-select, .filter-input {
    padding: 8px 12px; border-radius: 8px; border: 1px solid #c8d6cd;
    font-family: 'Poppins', sans-serif; font-size: 0.9rem; outline: none;
    min-width: 120px;
  }
  .filter-select:focus, .filter-input:focus {
    border-color: #00a98f; box-shadow: 0 0 0 2px rgba(0,169,143,0.15);
  }
  .filter-check { display: flex; align-items: center; gap: 4px; font-size: 0.9rem; color: #555; padding: 0 8px; }
  .filter-btn {
    padding: 8px 18px; background: #00a98f; color: white; border: none;
    border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s;
  }
  .filter-btn:hover { background: #008f7a; }
  .filter-clear { color: #888; font-size: 0.9rem; text-decoration: none; padding: 8px 12px; }
  .filter-clear:hover { color: #00a98f; }
</style>

<!-- Search Results -->
<% if (searchResults && searchResults.length > 0) { %>
  <p class="section-label">✨ Best matches for "<%= query %>"</p>
  <div class="book-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 340px));">
    <% for (let book of searchResults) { %>
      <div class="card">
        <% if (currentUser) { %>
          <% const saved = wishlistedIds && wishlistedIds.has(book._id.toString()); %>
          <button
            class="bs-wishlist-heart <%= saved ? 'is-saved' : '' %>"
            onclick="toggleWishlist('<%= book._id %>', this, false)"
            title="<%= saved ? 'Remove from wishlist' : 'Add to wishlist' %>">
            <%= saved ? '❤️' : '🤍' %>
          </button>
        <% } %>
        <% if (book.images && book.images.length) { %>
          <img class="card-img-top" alt="Book cover" src="<%= book.images[0].url %>">
        <% } else { %>
          <img class="card-img-top" alt="Default cover" src="https://res.cloudinary.com/douqbebwk/image/upload/v1600103881/YelpCamp/lz8jjv2gyynjil7lswf4.png">
        <% } %>
        <div class="card-body">
          <div>
            <h5 class="card-title"><%= book.title %></h5>
            <p class="card-text description-snippet"><%= book.description %></p>
          </div>
          <a href="/books/<%= book._id %>" class="btn-primary">View Details</a>
        </div>
      </div>
    <% } %>
  </div>
  <hr class="divider">
<% } %>

<!-- Personalised Recommendations -->
<% if (personalRecommendations && personalRecommendations.length > 0) { %>
  <p class="section-label">🎯 Recommended for You</p>
  <div class="rec-grid">
    <% personalRecommendations.forEach(b => { %>
      <a href="/books/<%= b._id %>" class="rec-card">
        <% if (b.images && b.images.length > 0) { %>
          <img src="<%= b.images[0].url %>" alt="<%= b.title %>">
        <% } %>
        <p class="rec-title"><%= b.title %></p>
        <p class="rec-author"><%= b.author %></p>
      </a>
    <% }) %>
  </div>
  <hr class="divider">
<% } %>

<!-- All Books (clustered — one card per unique title+author) -->
<p class="section-label">All Books</p>
<div class="book-grid">
  <% for (let cluster of clusters) { %>
    <%
      // A cluster is "saved" if ANY of its listings is in the user's
      // wishlist. Heart toggle targets the representative listing —
      // consistent with what the show page displays.
      let clusterSaved = false;
      if (currentUser && wishlistedIds) {
          clusterSaved = cluster.listing_ids.some(id => wishlistedIds.has(id.toString()));
      }
      const availBadgeClass = cluster.copies_available > 0 ? 'bs-badge--success' : 'bs-badge--danger';
      const availText = cluster.copies_available > 0
          ? `${cluster.copies_available} of ${cluster.copies_total} available`
          : `All ${cluster.copies_total} borrowed`;
    %>
    <div class="card">
      <% if (currentUser) { %>
        <button
          class="bs-wishlist-heart <%= clusterSaved ? 'is-saved' : '' %>"
          onclick="toggleWishlist('<%= cluster.representative_id %>', this, false)"
          title="<%= clusterSaved ? 'Remove from wishlist' : 'Add to wishlist' %>">
          <%= clusterSaved ? '❤️' : '🤍' %>
        </button>
      <% } %>

      <% if (cluster.copies_total > 1) { %>
        <span class="copies-chip">📚 <%= cluster.copies_total %> copies</span>
      <% } %>

      <% if (cluster.cover) { %>
        <img class="card-img-top" alt="Book cover" src="<%= cluster.cover %>">
      <% } else { %>
        <img class="card-img-top" alt="Default cover" src="https://res.cloudinary.com/douqbebwk/image/upload/v1600103881/YelpCamp/lz8jjv2gyynjil7lswf4.png">
      <% } %>
      <div class="card-body">
        <div>
          <h5 class="card-title"><%= cluster.title %></h5>
          <p class="card-author"><%= cluster.author %></p>
          <span class="bs-badge <%= availBadgeClass %>"><%= availText %></span>
          <p class="card-text description-snippet" style="margin-top: 0.8rem;"><%= cluster.description %></p>
        </div>
        <a href="/books/<%= cluster.representative_id %>" class="btn-primary">View Details</a>
      </div>
    </div>
  <% } %>
</div>

<style>
  /* Cluster-card extras — author line + "N copies" chip for multi-owner books */
  .card-author {
    text-align: center;
    color: #666;
    font-size: 0.85rem;
    margin: -0.25rem 0 0.6rem;
    font-style: italic;
  }
  .copies-chip {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(15, 118, 110, 0.95);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    z-index: 2;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }
</style>

<script>
    // Shared heart-toggle for every card on this page. Uses our design-system
    // is-saved class — the button visually flips between 🤍 (unsaved) and ❤️.
    // removeOnUnsave is false here because the books index always shows all
    // books regardless of wishlist state — contrast with views/wishlist which
    // removes the card on un-save.
    async function toggleWishlist(bookId, btn, removeOnUnsave) {
        try {
            const resp = await fetch(`/wishlist/${bookId}/toggle`, {
                method: 'POST',
                headers: { 'Accept': 'application/json' }
            });
            if (!resp.ok) {
                if (resp.status === 401) { window.location.href = '/login'; return; }
                throw new Error();
            }
            const data = await resp.json();
            if (data.saved) {
                btn.classList.add('is-saved');
                btn.textContent = '❤️';
                btn.title = 'Remove from wishlist';
            } else {
                btn.classList.remove('is-saved');
                btn.textContent = '🤍';
                btn.title = 'Add to wishlist';
            }
        } catch (e) {
            console.error('Wishlist toggle failed', e);
        }
    }
</script>