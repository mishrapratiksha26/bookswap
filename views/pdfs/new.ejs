<%- layout('layouts/boilerplate') %>

<div class="container mt-4" style="max-width: 640px;">
  <h2 class="mb-4">📤 Upload Study Material</h2>

  <form action="/pdfs" method="POST" enctype="multipart/form-data" class="validated-form">
    <div class="mb-3">
      <label class="form-label fw-semibold">Title *</label>
      <input type="text" name="title" class="form-control" placeholder="e.g. Operating Systems — Silberschatz" required>
    </div>

    <!-- Subject field removed after first user-test session. The Course
         dropdown below already captures the subject (course name +
         code), making a separate "Subject" field redundant data entry.
         The Python pipeline still references pdf.subject; the schema
         default of "" keeps existing code paths working, and the
         POST /pdfs route now derives subject from the course name
         when the form doesn't supply one. -->

    <!-- Department → Course cascade.
         Department choices are the canonical 17 IIT ISM departments.
         Course options are fetched on-change from /api/courses?dept=<code>
         which reads the scraped NEP catalogue seeded in courses collection.
         The <option value> stores "CODE - Name" (e.g. "MCC510 - Operating
         Systems") so the Python side can substring-match on either the
         course code or the name when linking PDFs to curriculum units. -->
    <div class="row mb-3">
      <div class="col">
        <label class="form-label fw-semibold">Department *</label>
        <select name="department" id="department-select" class="form-select" required>
          <option value="" disabled selected>Pick a department...</option>
          <% departments.forEach(d => { %>
            <option value="<%= d.code %>"><%= d.code %> — <%= d.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col">
        <label class="form-label fw-semibold">Course</label>
        <select name="course" id="course-select" class="form-select" disabled>
          <option value="" selected>Pick a department first...</option>
        </select>
        <div class="form-text" id="course-help">Course is optional — leave blank for generic material.</div>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Professor / Source</label>
      <input type="text" name="professor" class="form-control" placeholder="e.g. Prof. Sharma (optional)">
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Resource Type *</label>
      <select name="resource_type" id="resource-type-select" class="form-select" required>
        <option value="notes">Peer Notes</option>
        <option value="textbook">Textbook</option>
        <option value="previous_papers">Previous Year Papers (PYQs)</option>
        <option value="reference">Reference Material</option>
      </select>
    </div>

    <!-- Conditional block: Notes-specific metadata (shown when resource_type=notes) -->
    <div id="notes-extras" class="row mb-3">
      <div class="col">
        <label class="form-label fw-semibold">Semester</label>
        <select name="semester" class="form-select">
          <option value="">—</option>
          <% for (let s = 1; s <= 10; s++) { %>
            <option value="<%= s %>"><%= s %></option>
          <% } %>
        </select>
      </div>
      <div class="col">
        <label class="form-label fw-semibold">Topic covered</label>
        <input type="text" name="topic" class="form-control" placeholder="e.g. Process scheduling, deadlocks">
      </div>
    </div>

    <!-- Conditional block: PYQ-specific metadata (shown when resource_type=previous_papers) -->
    <div id="pyq-extras" class="row mb-3" style="display: none;">
      <div class="col">
        <label class="form-label fw-semibold">Exam type</label>
        <select name="exam_type" class="form-select">
          <option value="">—</option>
          <option value="mid_sem">Mid-sem</option>
          <option value="end_sem">End-sem</option>
          <option value="quiz">Quiz / Class test</option>
          <option value="assignment">Assignment</option>
        </select>
      </div>
      <div class="col">
        <label class="form-label fw-semibold">Year</label>
        <input type="number" name="year" class="form-control" min="2000" max="2099" placeholder="e.g. 2024">
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Description</label>
      <textarea name="description" class="form-control" rows="3" placeholder="Brief description of the content..."></textarea>
    </div>

    <div class="mb-4">
      <label class="form-label fw-semibold">PDF File *</label>
      <input type="file" name="pdf" class="form-control" accept=".pdf" required>
      <div class="form-text">Only PDF files. Max 10MB.</div>
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-success">Upload PDF</button>
      <a href="/pdfs" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
  // -------------------------------------------------------------------
  // Department → Course cascade
  // When the user picks a department, fetch that department's courses
  // from /api/courses?dept=<code> and populate the course <select>.
  // Cache responses in memory so switching between departments is free.
  // -------------------------------------------------------------------
  (function () {
    const deptSelect   = document.getElementById("department-select");
    const courseSelect = document.getElementById("course-select");
    const courseHelp   = document.getElementById("course-help");
    const cache = {};   // { deptCode: [{code, name, type}, ...] }

    async function loadCourses(deptCode) {
      courseSelect.disabled = true;
      courseSelect.innerHTML = '<option value="">Loading...</option>';

      let courses = cache[deptCode];
      if (!courses) {
        try {
          const resp = await fetch(`/api/courses?dept=${encodeURIComponent(deptCode)}`);
          if (!resp.ok) throw new Error("fetch failed");
          const data = await resp.json();
          courses = data.courses || [];
          cache[deptCode] = courses;
        } catch (e) {
          courseSelect.innerHTML = '<option value="">Could not load courses</option>';
          courseHelp.textContent = "Failed to load courses — you can still type below.";
          courseSelect.disabled = false;
          return;
        }
      }

      // Build option list. Value is "CODE - Name" so the Python side can
      // substring-match on either when linking PDFs to curriculum units.
      courseSelect.innerHTML = '<option value="">— No specific course —</option>' +
        courses.map(c => {
          const label = `${c.code} — ${c.name}` + (c.type && c.type !== "—" ? ` (${c.type})` : "");
          const value = `${c.code} - ${c.name}`;
          return `<option value="${value}">${label}</option>`;
        }).join("");

      courseSelect.disabled = false;
      courseHelp.textContent = `${courses.length} courses in this department. Optional — leave blank for generic material.`;
    }

    deptSelect.addEventListener("change", e => {
      if (e.target.value) loadCourses(e.target.value);
    });
  })();

  // -------------------------------------------------------------------
  // Resource-type → conditional extras.
  // Show notes-specific or PYQ-specific fields based on the dropdown;
  // hide the rest. "textbook" and "reference" show no extras.
  // -------------------------------------------------------------------
  (function () {
    const rtSelect    = document.getElementById("resource-type-select");
    const notesExtras = document.getElementById("notes-extras");
    const pyqExtras   = document.getElementById("pyq-extras");

    function syncExtras() {
      const v = rtSelect.value;
      notesExtras.style.display = (v === "notes") ? "" : "none";
      pyqExtras.style.display   = (v === "previous_papers") ? "" : "none";
    }

    rtSelect.addEventListener("change", syncExtras);
    syncExtras();   // correct initial state on first render
  })();
</script>
