<% layout('layouts/boilerplate') %>

<%# /pdfs/:id show page. Visually mirrors /books/show.ejs (same Poppins
    font, gradient background, two-column .book-card + .review-section
    layout, same cover-image carousel sizing) so a student moving
    between physical-book and digital-PDF detail pages doesn't see a
    completely different design language.

    Layout matches the books detail page exactly:
      LEFT (.book-card)
        cover image (or fallback icon)
        title (centred)
        resource-type badge (centred)
        metadata (Subject / Course / Department / Professor / Uploaded by)
        DESCRIPTION below the metadata block
        action button row — only Download (single CTA, aligned)

      RIGHT (.review-section)
        review form (rating + body, hidden for the uploader)
        review list (one card per review, with author + delete-own button)

    Reviews use the same Review model the books detail page uses;
    POST goes to /pdfs/:id/reviews, delete to /pdfs/:id/reviews/:rid.
    Uploaders can't review their own upload (same conflict-of-interest
    rule as books). Open-in-new-tab button removed per Shweta's
    pilot feedback (one CTA, not two). %>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #f4f6f8, #e8f5ee);
    min-height: 100vh;
  }
  .container { max-width: 1150px; }
  .book-section { display: flex; flex-wrap: wrap; gap: 2rem; }
  .book-card {
    flex: 1 1 48%;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    overflow: hidden;
    padding: 1.5rem;
  }
  .card-img-top {
    width: 100%;
    height: 380px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
  }
  .pdf-cover-fallback {
    width: 100%;
    height: 380px;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
    background: linear-gradient(135deg, #e8f5ee, #d1f0e0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: #198754;
  }
  .book-title {
    font-size: 1.7rem;
    font-weight: 600;
    color: #222;
    margin-top: 1rem;
    text-align: center;
  }
  .book-info p { margin: 0.5rem 0; color: #444; font-size: 0.95rem; }
  .pdf-description {
    margin-top: 1rem;
    color: #444;
    font-size: 0.95rem;
    line-height: 1.6;
    white-space: pre-line;
  }
  .btn-gradient {
    background: linear-gradient(90deg, #198754, #34c759);
    color: #fff !important;
    border: none;
    padding: 0.6rem 1.3rem;
    border-radius: 8px;
    font-weight: 500;
    transition: 0.3s ease;
  }
  .btn-gradient:hover {
    background: linear-gradient(90deg, #157347, #28a745);
    transform: translateY(-2px);
  }
  .btn-outline-danger { border-radius: 6px; }
  .pdf-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.2rem;
  }
  .review-section { flex: 1 1 48%; }
  .review-form, .review-list {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }
  .review-form h4 { font-weight: 600; color: #222; margin-bottom: 1rem; }
  .review-card {
    background: #f8faf9;
    border-left: 5px solid #34c759;
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 1rem;
  }
  .review-card h5 { font-size: 1rem; font-weight: 600; color: #198754; }
  .review-card p { color: #333; font-size: 0.95rem; }
  .review-card .card-subtitle { font-size: 0.85rem; }
  .resource-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-top: 0.5rem;
  }
  .resource-badge--textbook        { background: #cfe2ff; color: #084298; }
  .resource-badge--notes           { background: #d1fae5; color: #065f46; }
  .resource-badge--previous_papers { background: #fff3cd; color: #856404; }
  .resource-badge--reference       { background: #e2e3e5; color: #41464b; }
  @media (max-width: 992px) {
    .book-section { flex-direction: column; }
    .book-card, .review-section { flex: 1 1 100%; }
  }
</style>

<div class="container py-5">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/pdfs">Digital Library</a></li>
      <li class="breadcrumb-item active"><%= pdf.title %></li>
    </ol>
  </nav>

  <div class="book-section">

    <!-- ============================================================== -->
    <!-- LEFT: PDF Card                                                  -->
    <!-- Cover -> Title -> Badge -> Metadata -> Description -> Actions   -->
    <!-- ============================================================== -->
    <div class="book-card">

      <% if (pdf.cover_url) { %>
        <img src="<%= pdf.cover_url %>" class="card-img-top" alt="<%= pdf.title %> cover">
      <% } else { %>
        <div class="pdf-cover-fallback">📄</div>
      <% } %>

      <div class="book-title"><%= pdf.title %></div>

      <div class="text-center">
        <span class="resource-badge resource-badge--<%= pdf.resource_type || 'notes' %>">
          <%= (pdf.resource_type || 'notes').replace('_', ' ').toUpperCase() %>
        </span>
      </div>

      <div class="book-info mt-3">
        <% if (pdf.subject) { %>
          <p><strong>Subject:</strong> <%= pdf.subject %></p>
        <% } %>
        <% if (pdf.course) { %>
          <p><strong>Course:</strong> <%= pdf.course %></p>
        <% } %>
        <% if (pdf.department) { %>
          <p><strong>Department:</strong> <%= pdf.department %></p>
        <% } %>
        <% if (pdf.professor) { %>
          <p><strong>By Professor:</strong> <%= pdf.professor %></p>
        <% } %>
        <% if (pdf.uploadedBy) { %>
          <p><strong>Uploaded by:</strong> <%= pdf.uploadedBy.username %></p>
        <% } %>
        <% if (pdf.semester) { %>
          <p><strong>Semester:</strong> <%= pdf.semester %></p>
        <% } %>
        <% if (pdf.year) { %>
          <p><strong>Year:</strong> <%= pdf.year %></p>
        <% } %>
        <% if (pdf.exam_type) { %>
          <p><strong>Exam type:</strong> <%= pdf.exam_type %></p>
        <% } %>
        <% if (pdf.topic) { %>
          <p><strong>Topic:</strong> <%= pdf.topic %></p>
        <% } %>
        <p><strong>Downloads:</strong> <%= pdf.download_count || 0 %></p>
      </div>

      <% if (pdf.description) { %>
        <div class="pdf-description"><%= pdf.description %></div>
      <% } %>

      <%# Single primary CTA — Download. Open-in-new-tab dropped after
           Shweta's session ("no need for the open in new tab button").
           Both buttons used to route through /pdfs/:id/file; the
           download button still does, with the attachment header
           that forces a save. The Delete button only renders for
           the uploader, kept inline with the download button so all
           CTAs sit in one aligned row. %>
      <div class="pdf-actions">
        <a href="/pdfs/<%= pdf._id %>/file" class="btn btn-gradient">
          ⬇️ Download PDF
        </a>

        <% if (currentUser && pdf.uploadedBy && pdf.uploadedBy._id && pdf.uploadedBy._id.equals(currentUser._id)) { %>
          <form action="/pdfs/<%= pdf._id %>?_method=DELETE" method="POST" class="d-inline"
                onsubmit="return confirm('Delete this PDF permanently?')">
            <button type="submit" class="btn btn-outline-danger">Delete</button>
          </form>
        <% } %>
      </div>
    </div>
    <!-- End PDF Card -->


    <!-- ============================================================== -->
    <!-- RIGHT: Review Section                                           -->
    <!-- Mirrors books/show.ejs review block exactly. Form goes to       -->
    <!-- /pdfs/:id/reviews, delete to /pdfs/:id/reviews/:rid.            -->
    <!-- ============================================================== -->
    <div class="review-section">
      <%
        // Uploaders shouldn't rate their own upload — same conflict-of-
        // interest rule as physical books on /books/:id.
        const isUploader = currentUser && pdf.uploadedBy &&
                           pdf.uploadedBy._id &&
                           pdf.uploadedBy._id.equals(currentUser._id);
      %>

      <% if (currentUser && !isUploader) { %>
        <div class="review-form mb-4">
          <h4>Leave a Review</h4>
          <form action="/pdfs/<%= pdf._id %>/reviews" method="POST">
            <div class="mb-3">
              <label for="rating" class="form-label">Rating</label>
              <input type="range" class="form-range" min="1" max="5" name="review[rating]" id="rating">
            </div>
            <div class="mb-3">
              <label for="body" class="form-label">Review</label>
              <textarea class="form-control" name="review[body]" id="body" rows="3" required></textarea>
            </div>
            <button class="btn btn-gradient">Submit</button>
          </form>
        </div>
      <% } else if (isUploader) { %>
        <div class="alert alert-info">
          You uploaded this resource, so you can't review it. Reviews come from people who've used it.
        </div>
      <% } else { %>
        <div class="alert alert-warning">
          Login to leave a review: <a href="/login" class="alert-link">Login</a>
        </div>
      <% } %>

      <div class="review-list">
        <% if (!pdf.reviews || pdf.reviews.length === 0) { %>
          <p class="text-muted">No reviews yet.</p>
        <% } %>
        <% (pdf.reviews || []).forEach(review => { %>
          <% if (!review || !review.author) return; %>
          <div class="review-card">
            <h5>Rating: <%= review.rating %> ⭐</h5>
            <p><%= review.body %></p>
            <h6 class="card-subtitle text-muted">By <%= review.author.username %></h6>
            <% if (currentUser && review.author._id && review.author._id.toString() === currentUser._id.toString()) { %>
              <form action="/pdfs/<%= pdf._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-2">
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
    <!-- End Review Section -->

  </div>
</div>
