<% layout('layouts/boilerplate') %>

<%# /pdfs/:id show page. Visually mirrors /books/show.ejs (same Poppins
    font, gradient background, two-column .book-card + .review-section
    layout, same cover-image carousel sizing) so a student moving
    between physical-book and digital-PDF detail pages doesn't see a
    completely different design language. PDF-specific changes:
      • no borrow / chat-with-owner / wishlist workflow;
      • no reviews list (PDFs don't carry reviews);
      • the right column repurposes the review-section card for the
        description, upload metadata, and uploader info;
      • the action buttons are Download (forces attachment) + Open in
        new tab (inline) — both routed through /pdfs/:id/file (the
        server-side proxy that streams Cloudinary content with the
        right Content-Disposition header so direct delivery quirks
        don't bite the user).                                            %>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #f4f6f8, #e8f5ee);
    min-height: 100vh;
  }
  .container { max-width: 1150px; }
  .book-section { display: flex; flex-wrap: wrap; gap: 2rem; }
  .book-card {
    flex: 1 1 48%;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    overflow: hidden;
    padding: 1.5rem;
  }
  .card-img-top {
    width: 100%;
    height: 380px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
  }
  .pdf-cover-fallback {
    width: 100%;
    height: 380px;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
    background: linear-gradient(135deg, #e8f5ee, #d1f0e0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: #198754;
  }
  .book-title {
    font-size: 1.7rem;
    font-weight: 600;
    color: #222;
    margin-top: 1rem;
    text-align: center;
  }
  .book-info p { margin: 0.5rem 0; color: #444; font-size: 0.95rem; }
  .btn-gradient {
    background: linear-gradient(90deg, #198754, #34c759);
    color: #fff !important;
    border: none;
    padding: 0.6rem 1.3rem;
    border-radius: 8px;
    font-weight: 500;
    transition: 0.3s ease;
  }
  .btn-gradient:hover {
    background: linear-gradient(90deg, #157347, #28a745);
    transform: translateY(-2px);
  }
  .review-section { flex: 1 1 48%; }
  .review-form, .review-list {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }
  .review-form h4 { font-weight: 600; color: #222; margin-bottom: 1rem; }
  .review-card {
    background: #f8faf9;
    border-left: 5px solid #34c759;
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 1rem;
  }
  .review-card h5 { font-size: 1rem; font-weight: 600; color: #198754; }
  .review-card p { color: #333; font-size: 0.95rem; }
  .review-card .card-subtitle { font-size: 0.85rem; }
  .resource-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }
  .resource-badge--textbook        { background: #cfe2ff; color: #084298; }
  .resource-badge--notes           { background: #d1fae5; color: #065f46; }
  .resource-badge--previous_papers { background: #fff3cd; color: #856404; }
  .resource-badge--reference       { background: #e2e3e5; color: #41464b; }
  @media (max-width: 992px) {
    .book-section { flex-direction: column; }
    .book-card, .review-section { flex: 1 1 100%; }
  }
</style>

<div class="container py-5">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/pdfs">Digital Library</a></li>
      <li class="breadcrumb-item active"><%= pdf.title %></li>
    </ol>
  </nav>

  <div class="book-section">

    <!-- Left: PDF Card (cover + title + info + action buttons) -->
    <div class="book-card">
      <% if (pdf.cover_url) { %>
        <img src="<%= pdf.cover_url %>" class="card-img-top" alt="<%= pdf.title %> cover">
      <% } else { %>
        <div class="pdf-cover-fallback">📄</div>
      <% } %>

      <div class="book-title"><%= pdf.title %></div>

      <div class="text-center mt-2">
        <span class="resource-badge resource-badge--<%= pdf.resource_type || 'notes' %>">
          <%= (pdf.resource_type || 'notes').replace('_', ' ').toUpperCase() %>
        </span>
      </div>

      <div class="book-info mt-3">
        <% if (pdf.subject) { %>
          <p><strong>Subject:</strong> <%= pdf.subject %></p>
        <% } %>
        <% if (pdf.course) { %>
          <p><strong>Course:</strong> <%= pdf.course %></p>
        <% } %>
        <% if (pdf.department) { %>
          <p><strong>Department:</strong> <%= pdf.department %></p>
        <% } %>
        <% if (pdf.professor) { %>
          <p><strong>By Professor:</strong> <%= pdf.professor %></p>
        <% } %>
        <% if (pdf.uploadedBy) { %>
          <p><strong>Uploaded by:</strong> <%= pdf.uploadedBy.username %></p>
        <% } %>
      </div>

      <div class="text-center mt-3">
        <%# Both buttons hit /pdfs/:id/file — the server-side proxy
            that streams Cloudinary content with the right Content-
            Disposition header.  ?inline=1 → preview in new tab;
            no query → force a download.  Bypasses Cloudinary's
            free-plan delivery quirks for raw resources.            %>
        <a href="/pdfs/<%= pdf._id %>/file" class="btn btn-gradient mb-2">
          ⬇️ Download PDF
        </a>
        <a href="/pdfs/<%= pdf._id %>/file?inline=1" target="_blank"
           class="btn btn-outline-success mb-2 ms-2">
          👁️ Open in new tab
        </a>

        <% if (currentUser && pdf.uploadedBy && pdf.uploadedBy._id && pdf.uploadedBy._id.equals(currentUser._id)) { %>
          <form action="/pdfs/<%= pdf._id %>?_method=DELETE" method="POST" class="d-inline ms-2"
                onsubmit="return confirm('Delete this PDF permanently?')">
            <button type="submit" class="btn btn-outline-danger">Delete</button>
          </form>
        <% } %>
      </div>
    </div>
    <!-- End PDF Card -->

    <!-- Right: Description + metadata (replaces the review section
         from the book detail page; PDFs don't carry reviews). -->
    <div class="review-section">
      <% if (pdf.description) { %>
        <div class="review-form mb-4">
          <h4>About this resource</h4>
          <p style="color:#444; line-height:1.6; margin:0;"><%= pdf.description %></p>
        </div>
      <% } %>

      <div class="review-list">
        <h4 style="font-weight:600; color:#222; margin-bottom:1rem;">Resource Details</h4>

        <div class="review-card">
          <h5>📊 Stats</h5>
          <p>
            <strong>Downloads:</strong> <%= pdf.download_count || 0 %><br>
            <% if (pdf.created_at) { %>
              <strong>Uploaded:</strong> <%= new Date(pdf.created_at).toLocaleDateString() %><br>
            <% } %>
            <% if (pdf.semester) { %>
              <strong>Semester:</strong> <%= pdf.semester %><br>
            <% } %>
            <% if (pdf.year) { %>
              <strong>Year:</strong> <%= pdf.year %><br>
            <% } %>
            <% if (pdf.exam_type) { %>
              <strong>Exam type:</strong> <%= pdf.exam_type %><br>
            <% } %>
            <% if (pdf.topic) { %>
              <strong>Topic:</strong> <%= pdf.topic %>
            <% } %>
          </p>
        </div>

        <div class="review-card">
          <h5>💡 Tip</h5>
          <p>
            Click <strong>Download PDF</strong> to save a copy to your device,
            or <strong>Open in new tab</strong> to preview it in your browser
            without saving.
          </p>
        </div>

        <div class="text-center mt-3">
          <a href="/pdfs" class="btn btn-outline-secondary">← Back to Digital Library</a>
        </div>
      </div>
    </div>
    <!-- End Right Column -->

  </div>
</div>
