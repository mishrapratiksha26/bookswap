<%- layout('layouts/boilerplate') %>

<div class="container mt-4" style="max-width: 720px;">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/pdfs">Digital Library</a></li>
      <li class="breadcrumb-item active"><%= pdf.title %></li>
    </ol>
  </nav>

  <div class="card shadow-sm">
    <div class="card-body">
      <!-- Cover + Title row. Cover is autofilled from Google Books on upload
           (no file stored — just the URL). Fallback to a generic PDF icon
           when the uploader didn't pick a Google Books candidate. -->
      <div class="d-flex gap-3 align-items-start mb-2">
        <div style="flex-shrink: 0;">
          <% if (pdf.cover_url) { %>
            <img src="<%= pdf.cover_url %>" alt="Cover" class="rounded shadow-sm"
                 style="width: 110px; height: 160px; object-fit: cover;">
          <% } else { %>
            <div class="rounded bg-light d-flex align-items-center justify-content-center border"
                 style="width: 110px; height: 160px; font-size: 3rem;">📄</div>
          <% } %>
        </div>
        <div class="flex-grow-1">
          <span class="badge bg-<%= pdf.resource_type === 'textbook' ? 'primary' : pdf.resource_type === 'notes' ? 'success' : pdf.resource_type === 'previous_papers' ? 'warning text-dark' : 'secondary' %> mb-2">
            <%= pdf.resource_type.replace('_', ' ').toUpperCase() %>
          </span>
          <h2 class="card-title mt-1 mb-0"><%= pdf.title %></h2>
        </div>
      </div>

      <!-- Metadata -->
      <table class="table table-sm table-borderless mt-3 mb-3" style="max-width: 400px;">
        <tr><td class="text-muted">Subject</td><td><strong><%= pdf.subject %></strong></td></tr>
        <% if (pdf.course) { %><tr><td class="text-muted">Course</td><td><%= pdf.course %></td></tr><% } %>
        <% if (pdf.department) { %><tr><td class="text-muted">Department</td><td><%= pdf.department %></td></tr><% } %>
        <% if (pdf.professor) { %><tr><td class="text-muted">By</td><td><%= pdf.professor %></td></tr><% } %>
        <% if (pdf.uploadedBy) { %><tr><td class="text-muted">Uploaded by</td><td><%= pdf.uploadedBy.username %></td></tr><% } %>
        <tr><td class="text-muted">Downloads</td><td><%= pdf.download_count || 0 %></td></tr>
      </table>

      <% if (pdf.description) { %>
        <p class="card-text"><%= pdf.description %></p>
      <% } %>

      <%# Chapter list intentionally hidden from the user-facing PDF
           show page — pilot + second user-test sessions both found
           the heuristic-extracted entries unreliable and confusing
           ("📄 B / 📄 Solid / 📄 P" on textbooks without an embedded
           TOC).
           pdf.chapter_headings is still populated by /embed-pdf at
           upload time and is still used internally by the curriculum
           matcher (§3.6 unit→chapter mapping) — that consumer can
           tolerate the noise because it ranks chapters by cosine
           similarity to the unit topic, so wrong-domain entries
           score low and never surface. The display surface is the
           weak link; removing the public render is the right fix
           pending the §6.4 OCR-pipeline improvement work. %>


      <!-- Action buttons -->
      <%
        // Build a download URL that forces the browser to save the
        // file as a real .pdf — Cloudinary's `fl_attachment:<filename>`
        // delivery flag injects a Content-Disposition: attachment
        // header AND a sensible default filename, so even the
        // (rare) old uploads where public_id lacks the .pdf
        // extension still download as a proper PDF.
        //
        // The flag is inserted right after `/raw/upload/` in the URL.
        // Filename is sanitised the same way as the upload-time
        // public_id so it round-trips cleanly.
        const safeName = (pdf.title || "book")
          .replace(/[^a-zA-Z0-9_-]/g, "_")
          .slice(0, 100) + ".pdf";
        const dlUrl = (pdf.cloudinary_url || "").replace(
          "/raw/upload/",
          `/raw/upload/fl_attachment:${safeName}/`
        );
      %>
      <div class="d-flex gap-2 flex-wrap mt-3">
        <a href="<%= dlUrl || pdf.cloudinary_url %>" class="btn btn-primary"
           download="<%= safeName %>"
           onclick="fetch('/pdfs/<%= pdf._id %>/download', {method:'POST'})">
          ⬇️ Download PDF
        </a>
        <a href="<%= pdf.cloudinary_url %>" target="_blank" class="btn btn-outline-primary">
          👁️ Open in new tab
        </a>
        <a href="/pdfs" class="btn btn-outline-secondary">Back to Library</a>

        <% if (currentUser && pdf.uploadedBy && pdf.uploadedBy._id && pdf.uploadedBy._id.equals(currentUser._id)) { %>
          <form action="/pdfs/<%= pdf._id %>?_method=DELETE" method="POST" class="d-inline"
                onsubmit="return confirm('Delete this PDF permanently?')">
            <button type="submit" class="btn btn-outline-danger">Delete</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>
