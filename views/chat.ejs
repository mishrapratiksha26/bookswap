<% layout('layouts/boilerplate') %>
<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');

/* Color Variables for Light and Dark Themes */
:root {
  --bg-main: #f4f6f8;
  --bg-chat: #fff;
  --bg-sidebar: #f0f0f0;
  --bg-header: #128c7e;
  --bg-sent: #dcf8c6;
  --bg-received: #fff;
  --bg-input: #f9fafb;
  --text-main: #232b2b;
  --text-secondary: #606c76;
  --text-white: #fff;
  --accent: #25d366;
  --danger: #dc3545;
  --shadow: 0 8px 24px rgba(0,0,0,0.13);
}

/* Dark Mode Support */
@media (prefers-color-scheme: dark) {
  :root {
    --bg-main: #181a1b;
    --bg-chat: #212324;
    --bg-sidebar: #222326;
    --bg-header: #1d2f2f;
    --bg-sent: #205d48;
    --bg-received: #232524;
    --bg-input: #1a1c1d;
    --text-main: #fafbfc;
    --text-secondary: #dadada;
    --text-white: #fff;
    --accent: #23c778;
    --danger: #e05270;
    --shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
}

body {
  font-family: 'Poppins', sans-serif;
  background-color: var(--bg-main);
  margin: 0;
  padding: 0;
  color: var(--text-main);
}

.chat-app {
  display: flex;
  height: calc(100vh - 48px);
  overflow: hidden;
  margin: 24px 16px;
  border-radius: 16px;
  box-shadow: var(--shadow);
  background-color: var(--bg-chat);
}

.sidebar {
  width: 280px;
  background: var(--bg-sidebar);
  border-right: 1px solid #e0e0e0;
  display: flex;
  flex-direction: column;
  transition: background 0.3s;
}

.sidebar-header {
  padding: 18px;
  background: var(--bg-header);
  color: var(--text-white);
  font-weight: 600;
  font-size: 1.2rem;
  border-top-left-radius: 16px;
}

.search-bar {
  padding: 13px;
  border-bottom: 1px solid #ddd;
}
.search-bar input {
  width: 100%;
  padding: 8px 14px;
  border-radius: 20px;
  border: 1px solid #bbb;
  background: var(--bg-input);
  font-size: 0.99rem;
  transition: border-color 0.2s;
}

.contact-list {
  flex: 1;
  overflow-y: auto;
}
.contact-item {
  padding: 14px 18px;
  display: flex;
  align-items: center;
  border-bottom: 1px solid #e7e7e7;
  text-decoration: none;
  color: var(--text-main);
  transition: background 0.19s;
  cursor: pointer;
}
.contact-item:hover,
.contact-item.active {
  background: #dffaf1;
  font-weight: 600;
}

.contact-initial {
  min-width: 38px;
  min-height: 38px;
  border-radius: 50%;
  background: var(--accent);
  color: var(--text-white);
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.11);
  font-size: 1.02rem;
}

/* Chat Window */
.chat-window {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: var(--bg-chat);
  position: relative;
  border-top-right-radius: 16px;
}

.chat-header {
  background: var(--bg-header);
  color: var(--text-white);
  padding: 20px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 1rem;
  font-weight: 500;
  box-shadow: 0 2px 6px rgba(40,40,40,0.09);
}

.chat-box {
  flex: 1;
  padding: 24px 18px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 15px;
  background: var(--bg-chat);
}

.chat-message-row {
  display: flex;
  align-items: flex-end;
}

.sent-row {
  justify-content: flex-end;
}
.received-row {
  justify-content: flex-start;
}
.initial-bubble {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--accent);
  color: var(--text-white);
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  margin: 0 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
.message-bubble {
  padding: 11px 19px;
  border-radius: 16px;
  max-width: 64vw;
  font-size: 1.04rem;
  word-wrap: break-word;
  box-shadow: 0 2px 8px rgba(0,0,0,0.10);
  background: var(--bg-received);
}
.sent-row .message-bubble {
  background: var(--bg-sent);
  color: var(--text-main);
}
.received-row .message-bubble {
  background: var(--bg-received);
  border: 1px solid #e3e3e3;
}

/* Timestamps */
.timestamp {
  font-size: 0.69rem;
  color: var(--text-secondary);
  margin-top: 3px;
  text-align: right;
  opacity: 0.9;
}

/* Chat Input */
.chat-input {
  display: flex;
  padding: 17px;
  border-top: 1px solid #e2e2e2;
  background: var(--bg-input);
  align-items: center;
  gap: 12px;
  border-bottom-right-radius: 16px;
}
.chat-input input {
  flex: 1;
  padding: 11px 20px;
  border-radius: 20px;
  border: 1px solid #c5cadd;
  font-size: 1rem;
  background: #fff;
  transition: box-shadow 0.2s;
}
.chat-input input:focus {
  border-color: var(--accent);
  outline: none;
  box-shadow: 0 0 4px rgba(38,200,107,0.12);
}
.chat-input button {
  padding: 10px 24px;
  border-radius: 20px;
  border: none;
  background: var(--accent);
  color: var(--text-white);
  font-weight: 600;
  font-size: 1rem;
  box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  transition: background 0.3s;
  cursor: pointer;
}
.chat-input button:hover {
  background: #23b765;
}

/* Dropdown Enhancements */
.dropdown-menu {
  z-index: 1003;
  box-shadow: 0 2px 13px rgba(0,0,0,0.15);
  border-radius: 14px;
  overflow: hidden;
  min-width: 140px;
  padding: 8px 0;
  background: #fff;
}
.dropdown-item {
  font-size: 0.97rem;
  padding: 11px 24px;
  transition: background 0.22s;
}
.dropdown-item:hover {
  background: #eee;
}
.dropdown-item.text-danger {
  color: var(--danger);
  font-weight: 600;
}
.dropdown-item.text-danger:hover {
  background: #ffe3e6;
  color: #c4304f;
}

/* Modal */
.modal-content {
  border-radius: 18px;
  background: var(--bg-chat);
}

/* Toast */
.toast {
  position: fixed;
  bottom: 22px;
  right: 42px;
  min-width: 180px;
  background: var(--bg-header);
  color: var(--text-white);
  padding: 13px 28px;
  border-radius: 22px;
  font-size: 1.01rem;
  font-weight: 600;
  letter-spacing: 0.5px;
  display: none;
  box-shadow: var(--shadow);
  z-index: 2000;
  animation: fadein 0.4s;
}

@keyframes fadein {
  from { opacity: 0;}
  to { opacity: 1;}
}
</style>

<div class="chat-app">
  <!-- Sidebar -->
  <div class="sidebar">
    <div class="sidebar-header">Chats</div>
    <div class="search-bar">
      <input type="text" placeholder="Search contacts..." />
    </div>
    <div class="contact-list">
      <% contacts.forEach(contact => { %>
        <a href="/chat/<%= contact._id %>" class="contact-item <%= contact._id.toString() === chatPartnerId.toString() ? 'active' : '' %>">
          <div class="contact-initial"><%= contact.username.charAt(0).toUpperCase() %></div>
          <div><%= contact.username %></div>
        </a>
      <% }) %>
    </div>
  </div>

  <!-- Chat Window -->
  <div class="chat-window">
    <div class="chat-header d-flex justify-content-between align-items-center">
      <div>Chat with <%= chatPartnerName %></div>
      <div class="icons d-flex align-items-center gap-3">
        <i class="bi bi-telephone-fill"></i>
        <i class="bi bi-camera-video-fill"></i>
        <div class="dropdown-wrapper position-relative">
          <div class="dropdown">
            <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
              Options
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#confirmDelete">Delete Chat</button>
              </li>
              <li>
                <form method="POST" action="/chat/<%= chatPartnerId %>/block" onsubmit="showToast('Contact blocked')">
                  <button class="dropdown-item text-danger">Block Contact</button>
                </form>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div id="chat-box" class="chat-box">
      <% messages.forEach(msg => {
        const isSent = msg.sender._id.toString() === currentUserId.toString();
        const initials = msg.sender.username ? msg.sender.username.charAt(0).toUpperCase() : '?';
      %>
        <div class="chat-message-row <%= isSent ? 'sent-row' : 'received-row' %>">
          <% if (isSent) { %>
            <div class="message-bubble">
              <%= msg.message %>
              <div class="timestamp">
                <%= new Date(msg.timestamp).toLocaleString('en-IN', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' }) %>
                <span class="ticks"><%= chatPartnerBlockedMe ? '✓' : '✓✓' %></span>
              </div>
            </div>
            <div class="initial-bubble">You</div>
          <% } else { %>
            <div class="initial-bubble"><%= initials %></div>
            <div class="message-bubble">
              <%= msg.message %>
              <div class="timestamp">
                <%= new Date(msg.timestamp).toLocaleString('en-IN', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' }) %>
              </div>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>

    <% if (isBlocked) { %>
      <div class="chat-input text-center text-muted p-3 d-flex flex-column align-items-center justify-content-center">
        <div>You have blocked this contact. Unblock to continue chatting.</div>
        <form method="POST" action="/chat/<%= chatPartnerId %>/unblock" onsubmit="showToast('Contact unblocked')" class="mt-3">
          <button class="btn btn-success">Unblock</button>
        </form>
      </div>
    <% } else { %>
      <div class="chat-input">
        <input id="messageInput" type="text" placeholder="Type your message..." />
        <button onclick="sendMessage()">Send</button>
      </div>
    <% } %>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="confirmDelete" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
  <div class="modal-dialog">
    <form method="POST" action="/chat/<%= chatPartnerId %>/delete" onsubmit="showToast('Chat deleted')">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="confirmDeleteLabel">Confirm Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          Are you sure you want to delete this chat? This action cannot be undone.
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">Delete</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>


<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const currentUserId = "<%= currentUserId %>";
  const chatPartnerId = "<%= chatPartnerId %>";
  const isBlockedClient = "<%= isBlocked ? 'true' : 'false' %>";

  socket.on("receiveMessage", (data) => {
    if (isBlockedClient || !(data.receiverId === currentUserId || data.senderId === currentUserId)) return;

    const chatBox = document.getElementById("chat-box");
    const msg = document.createElement("div");
    msg.classList.add("chat-message-row");
    msg.classList.add(data.senderId === currentUserId ? "sent-row" : "received-row");

    const initials = data.senderId === currentUserId ? "You" : "<%= chatPartnerName.charAt(0).toUpperCase() %>";
    const timestamp = new Date().toLocaleString('en-IN', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' });

    msg.innerHTML = `
      ${data.senderId === currentUserId ? `
        <div class="message-bubble">
          ${data.message}
          <div class="timestamp">${timestamp}<span class="ticks">✓✓</span></div>
        </div>
        <div class="initial-bubble">You</div>
      ` : `
        <div class="initial-bubble">${initials}</div>
        <div class="message-bubble">
          ${data.message}
          <div class="timestamp">${timestamp}</div>
        </div>
      `}
    `;
    chatBox.appendChild(msg);
    chatBox.scrollTop = chatBox.scrollHeight;
  });

  function sendMessage() {
  const input = document.getElementById("messageInput");
  const message = input.value.trim();
  if (!message || isBlockedClient === "true") return;

  const chatBox = document.getElementById("chat-box");
  const timestamp = new Date().toLocaleString('en-IN', {
    hour: '2-digit',
    minute: '2-digit',
    day: 'numeric',
    month: 'short'
  });

  // Create optimistic message bubble
  const msg = document.createElement("div");
  msg.classList.add("chat-message-row", "sent-row");
  msg.innerHTML = `
    <div class="message-bubble">
      ${message}
      <div class="timestamp">${timestamp}<span class="ticks">✓✓</span></div>
    </div>
    <div class="initial-bubble">You</div>
  `;
  chatBox.appendChild(msg);
  chatBox.scrollTop = chatBox.scrollHeight;

  // Emit to server
  socket.emit("sendMessage", {
    senderId: currentUserId,
    receiverId: chatPartnerId,
    message
  });

  input.value = "";
}

  function showToast(message) {
    const toast = document.getElementById("toast");
    toast.textContent = message;
    toast.style.display = "block";
    setTimeout(() => {
      toast.style.display = "none";
    }, 3000);
  }

  window.onload = () => {
    const chatBox = document.getElementById("chat-box");
    chatBox.scrollTop = chatBox.scrollHeight;
  };
</script>