<% layout('layouts/boilerplate') %>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">

<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');

:root {
  --bg-main: #f4f6f8;
  --bg-chat: #fff;
  --bg-sidebar: #f0f0f0;
  --bg-header: #198754;
  --bg-sent: #d1e7dd;
  --bg-received: #f8f9fa;
  --bg-input: #f9fafb;
  --text-main: #232b2b;
  --text-secondary: #606c76;
  --text-white: #fff;
  --accent: #198754;
  --danger: #dc3545;
  --shadow: 0 4px 20px rgba(0,0,0,0.10);
}

body {
  font-family: 'Poppins', sans-serif;
  background: linear-gradient(135deg, #f4f6f8, #e8f5ee);
  margin: 0;
  padding: 0;
}

.chat-wrapper {
  max-width: 1100px;
  margin: 32px auto;
  padding: 0 16px;
  height: calc(100vh - 120px);
  display: flex;
  flex-direction: column;
}

.chat-app {
  display: flex;
  flex: 1;
  border-radius: 20px;
  box-shadow: var(--shadow);
  overflow: hidden;
  background: var(--bg-chat);
  min-height: 0;
}

/* Sidebar */
.sidebar {
  width: 260px;
  background: #f8faf9;
  border-right: 1px solid #e0e0e0;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.sidebar-header {
  padding: 20px 18px;
  background: var(--bg-header);
  color: var(--text-white);
  font-weight: 600;
  font-size: 1.1rem;
}

.search-bar {
  padding: 12px;
  border-bottom: 1px solid #e0e0e0;
}
.search-bar input {
  width: 100%;
  padding: 8px 14px;
  border-radius: 20px;
  border: 1px solid #ddd;
  background: #fff;
  font-size: 0.9rem;
  box-sizing: border-box;
}

.contact-list { flex: 1; overflow-y: auto; }

.contact-item {
  padding: 12px 16px;
  display: flex;
  align-items: center;
  border-bottom: 1px solid #f0f0f0;
  text-decoration: none;
  color: var(--text-main);
  transition: background 0.15s;
  gap: 12px;
}
.contact-item:hover { background: #eafaf1; }
.contact-item.active { background: #d1e7dd; font-weight: 600; }

.contact-initial {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.95rem;
  flex-shrink: 0;
}

/* Chat Window */
.chat-window {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.chat-header {
  background: var(--bg-header);
  color: #fff;
  padding: 16px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 1rem;
  font-weight: 600;
  flex-shrink: 0;
}

.chat-box {
  flex: 1;
  padding: 20px 24px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: #fafffe;
  min-height: 0;
}

.chat-message-row { display: flex; align-items: flex-end; gap: 8px; }
.sent-row { justify-content: flex-end; }
.received-row { justify-content: flex-start; }

.initial-bubble {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8rem;
  flex-shrink: 0;
}

.message-bubble {
  padding: 10px 16px;
  border-radius: 16px;
  max-width: 60%;
  font-size: 0.95rem;
  word-wrap: break-word;
  line-height: 1.5;
}
.sent-row .message-bubble {
  background: var(--bg-sent);
  color: var(--text-main);
  border-bottom-right-radius: 4px;
}
.received-row .message-bubble {
  background: var(--bg-received);
  border: 1px solid #e3e3e3;
  border-bottom-left-radius: 4px;
}

.timestamp {
  font-size: 0.68rem;
  color: var(--text-secondary);
  margin-top: 4px;
  text-align: right;
}

/* Input */
.chat-input {
  display: flex;
  padding: 14px 20px;
  border-top: 1px solid #e2e2e2;
  background: var(--bg-input);
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.chat-input input {
  flex: 1;
  padding: 10px 18px;
  border-radius: 20px;
  border: 1px solid #ddd;
  font-size: 0.95rem;
  background: #fff;
  font-family: 'Poppins', sans-serif;
}
.chat-input input:focus {
  border-color: var(--accent);
  outline: none;
}
.chat-input button {
  padding: 10px 22px;
  border-radius: 20px;
  border: none;
  background: var(--accent);
  color: #fff;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: background 0.2s;
  font-family: 'Poppins', sans-serif;
}
.chat-input button:hover { background: #157347; }

/* Blocked state */
.blocked-bar {
  padding: 16px 24px;
  background: #fff3cd;
  text-align: center;
  font-size: 0.9rem;
  color: #856404;
  border-top: 1px solid #ffeeba;
}

/* Dropdown */
.dropdown-menu {
  border-radius: 12px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  border: none;
  padding: 6px 0;
}
.dropdown-item { padding: 10px 20px; font-size: 0.9rem; }
.dropdown-item.text-danger { color: var(--danger); font-weight: 600; }

/* Toast */
.toast-msg {
  position: fixed;
  bottom: 24px;
  right: 32px;
  background: #198754;
  color: #fff;
  padding: 12px 24px;
  border-radius: 20px;
  font-size: 0.95rem;
  font-weight: 600;
  display: none;
  box-shadow: var(--shadow);
  z-index: 2000;
}

/* Empty chat state */
.empty-chat {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #aaa;
  font-size: 1rem;
}
</style>

<div class="chat-wrapper">
  <div class="chat-app">

    <!-- Sidebar -->
    <div class="sidebar">
      <div class="sidebar-header">💬 Chats</div>
      <div class="search-bar">
        <input type="text" placeholder="Search contacts..." />
      </div>
      <div class="contact-list">
        <% contacts.forEach(contact => { %>
          <a href="/chat/<%= contact._id %>"
             class="contact-item <%= chatPartnerId && contact._id.toString() === chatPartnerId.toString() ? 'active' : '' %>">
            <div class="contact-initial"><%= contact.username.charAt(0).toUpperCase() %></div>
            <div><%= contact.username %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <!-- Chat Window -->
    <div class="chat-window">
      <div class="chat-header">
        <div>Chat with <%= chatPartnerName || 'Select a contact' %></div>
        <div class="dropdown">
          <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown">Options</button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li>
              <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#confirmDelete">Delete Chat</button>
            </li>
            <li>
              <form method="POST" action="/chat/<%= chatPartnerId %>/block">
                <button class="dropdown-item text-danger">Block Contact</button>
              </form>
            </li>
          </ul>
        </div>
      </div>

      <!-- Messages -->
      <div id="chat-box" class="chat-box">
        <% if (messages.length === 0) { %>
          <div class="empty-chat">No messages yet. Say hello! 👋</div>
        <% } %>
        <% messages.forEach(msg => {
          const isSent = msg.sender._id.toString() === currentUserId.toString();
          const initials = msg.sender.username ? msg.sender.username.charAt(0).toUpperCase() : '?';
        %>
          <div class="chat-message-row <%= isSent ? 'sent-row' : 'received-row' %>">
            <% if (isSent) { %>
              <div class="message-bubble">
                <%= msg.message %>
                <div class="timestamp">
                  <%= new Date(msg.timestamp).toLocaleString('en-IN', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' }) %>
                </div>
              </div>
              <div class="initial-bubble">You</div>
            <% } else { %>
              <div class="initial-bubble"><%= initials %></div>
              <div class="message-bubble">
                <%= msg.message %>
                <div class="timestamp">
                  <%= new Date(msg.timestamp).toLocaleString('en-IN', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' }) %>
                </div>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>

      <% if (isBlocked) { %>
        <div class="blocked-bar">
          You have blocked this contact.
          <form method="POST" action="/chat/<%= chatPartnerId %>/unblock" style="display:inline; margin-left:12px;">
            <button class="btn btn-sm btn-success">Unblock</button>
          </form>
        </div>
      <% } else { %>
        <div class="chat-input">
          <input id="messageInput" type="text" placeholder="Type your message..." />
          <button onclick="sendMessage()">Send</button>
        </div>
      <% } %>
    </div>

  </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="confirmDelete" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <form method="POST" action="/chat/<%= chatPartnerId %>/delete">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Confirm Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">Are you sure you want to delete this chat? This cannot be undone.</div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">Delete</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div id="toast" class="toast-msg"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const currentUserId = "<%= currentUserId %>";
  const chatPartnerId = "<%= chatPartnerId %>";
  const isBlockedClient = "<%= isBlocked ? 'true' : 'false' %>";

socket.on("receiveMessage", (data) => {
  if (isBlockedClient === 'true') return;
  if (data.senderId === currentUserId) return; // fix duplicate messages
  if (!(data.receiverId === currentUserId || data.senderId === currentUserId)) return;
  // rest stays the same

    const chatBox = document.getElementById("chat-box");
    const msg = document.createElement("div");
    msg.classList.add("chat-message-row");
    msg.classList.add(data.senderId === currentUserId ? "sent-row" : "received-row");
    const initials = data.senderId === currentUserId ? "You" : "<%= chatPartnerName ? chatPartnerName.charAt(0).toUpperCase() : '?' %>";
    const timestamp = new Date().toLocaleString('en-IN', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' });
    msg.innerHTML = data.senderId === currentUserId ? `
      <div class="message-bubble">${data.message}<div class="timestamp">${timestamp}</div></div>
      <div class="initial-bubble">You</div>
    ` : `
      <div class="initial-bubble">${initials}</div>
      <div class="message-bubble">${data.message}<div class="timestamp">${timestamp}</div></div>
    `;
    chatBox.appendChild(msg);
    chatBox.scrollTop = chatBox.scrollHeight;
  });

  function sendMessage() {
    const input = document.getElementById("messageInput");
    const message = input.value.trim();
    if (!message || isBlockedClient === "true") return;
    const chatBox = document.getElementById("chat-box");
    const timestamp = new Date().toLocaleString('en-IN', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' });
    const msg = document.createElement("div");
    msg.classList.add("chat-message-row", "sent-row");
    msg.innerHTML = `
      <div class="message-bubble">${message}<div class="timestamp">${timestamp}</div></div>
      <div class="initial-bubble">You</div>
    `;
    chatBox.appendChild(msg);
    chatBox.scrollTop = chatBox.scrollHeight;
    socket.emit("sendMessage", { senderId: currentUserId, receiverId: chatPartnerId, message });
    input.value = "";
  }

  function showToast(message) {
    const toast = document.getElementById("toast");
    toast.textContent = message;
    toast.style.display = "block";
    setTimeout(() => { toast.style.display = "none"; }, 3000);
  }

  // Handle Enter key
  document.getElementById('messageInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') sendMessage();
  });

window.onload = () => {
  const chatBox = document.getElementById("chat-box");
  chatBox.scrollTop = chatBox.scrollHeight;

  const params = new URLSearchParams(window.location.search);
  const suggestion = params.get('suggestion');
  if (suggestion) {
    document.getElementById('messageInput').value = suggestion;
    // Clean URL so suggestion doesn't reappear on refresh
    window.history.replaceState({}, document.title, window.location.pathname);
  }
};
</script>