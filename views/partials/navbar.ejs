<!--
  Modern BookSwap nav. Uses design-system classes from public/stylesheets/app.css.
  No Bootstrap navbar classes — cleaner and doesn't fight our tokens.
-->
<nav class="bs-navbar">
    <a class="bs-navbar__brand" href="/">📚 BookSwap</a>

    <div class="bs-navbar__nav">
        <a href="/books">Books</a>
        <a href="/pdfs">Library</a>
        <a href="/curriculum">Curriculum</a>
        <% if (currentUser) { %>
            <a href="/wishlist">Wishlist</a>
            <a href="/chat">Chats</a>
        <% } %>
    </div>

    <div class="bs-navbar__nav">
        <% if (!currentUser) { %>
            <a href="/login">Login</a>
            <a class="bs-navbar__cta" href="/register">Sign up</a>
        <% } else { %>
            <a href="/books/new" class="bs-navbar__cta">＋ Post Book</a>
            <a href="/profile"><%= currentUser.username %></a>
            <a href="/logout">Logout</a>
        <% } %>
    </div>
</nav>
